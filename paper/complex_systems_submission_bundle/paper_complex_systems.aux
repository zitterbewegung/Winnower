\@writefile{toc}{\contentsline {title}{\GenericError  {               }{LaTeX Error: No \title given}{See the LaTeX manual or LaTeX Companion for explanation.}{Try typing  <return>  to proceed.\MessageBreak If that doesn't work, type  X <return>  to quit.}\ Relative-Periodic Domain Selection}{1}{Doc-Start}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Relative-periodic domain selection by Bernoulli NML. The first sentence of the caption serves as a title. Starting from an observed spacetime, the method enumerates candidate period/shift pairs, induces an orbit partition for each candidate, constructs the nearest majority-vote background, and scores the candidate by a Bernoulli NML criterion. The output is a selected periodic background together with a residual mask that isolates structured departures from that background.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:algorithm}{{1}{2}{Relative-periodic domain selection by Bernoulli NML. The first sentence of the caption serves as a title. Starting from an observed spacetime, the method enumerates candidate period/shift pairs, induces an orbit partition for each candidate, constructs the nearest majority-vote background, and scores the candidate by a Bernoulli NML criterion. The output is a selected periodic background together with a residual mask that isolates structured departures from that background}{figure.1}{}}
