/-
If (p2, s2) is a velocity-matched multiple of (p1, s1), then the orbit relation of (p2, s2) implies the orbit relation of (p1, s1).
-/
theorem OrbitRel_refinement (p1 p2 : ℕ) (s1 s2 : S) (m : ℕ) (h_p : p2 = m * p1) (h_s : s2 = m • s1) :
  ∀ x y, OrbitRel p2 s2 x y → OrbitRel p1 s1 x y := by
    rintro ⟨ t, x ⟩ ⟨ u, y ⟩ ⟨ k, hk ⟩ ; use k * m; simp_all +decide [ mul_assoc, mul_left_comm, mul_comm ] ;
    simp +decide [ mul_comm, MulAction.mul_smul ]

/-
Theorem 2: If (p2, s2) is a velocity-matched multiple of (p1, s1), then the minimum Hamming distance for (p2, s2) is less than or equal to that for (p1, s1).
-/
/-- The minimum Hamming distance achievable by a relative-periodic model with parameters (p, s). -/
def MinHammingDistance (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) : ℕ :=
  HammingDistance U (OptimalProjection U T p s hp) T

/-- Theorem 2: Monotonicity under Velocity-Matched Refinement. -/
theorem Monotonicity_Under_Refinement (U : Spacetime S) (T : ℕ) (p1 p2 : ℕ) (s1 s2 : S) (m : ℕ)
  (hp1 : p1 > 0) (hp2 : p2 > 0) (h_p : p2 = m * p1) (h_s : s2 = m • s1) :
  MinHammingDistance U T p2 s2 hp2 ≤ MinHammingDistance U T p1 s1 hp1 := by
    -- Since $p2 = m * p1$ and $s2 = m • s1$, any relative-periodic model with $(p1, s1)$ is also relative-periodic with $(p2, s2)$.
    have h_rel_periodic : ∀ B : Spacetime S, IsRelativePeriodic B p1 s1 → IsRelativePeriodic B p2 s2 := by
      intro B hB;
      intro t x; subst_vars; induction' m with m ih <;> simp_all +decide [ mul_assoc, add_mul ] ;
      by_cases hm : 0 < m <;> simp_all +decide [ add_smul, ← add_assoc ];
      · rw [ ← ih, hB ];
      · exact hB t x;
    apply le_trans (OptimalProjection_minimizes_HammingDistance U T p2 s2 hp2 (OptimalProjection U T p1 s1 hp1) (h_rel_periodic _ (OptimalProjection_is_RelativePeriodic U T p1 s1 hp1))) (by
    rfl)

/-
Definition of OrbitSize.
-/
/-- The total size of an orbit class within a window T. -/
def OrbitSize (T : ℕ) (O : Set (ℕ × S)) : ℕ :=
  ∑ t ∈ Finset.range T, ∑ x : S, if (t, x) ∈ O then 1 else 0

/-
Definition of NLL and NML score. NLL is the sum of binary entropies of orbit classes weighted by their size. NML adds a complexity penalty proportional to the number of orbit classes and log T.
-/
noncomputable def NLL (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) : ℝ :=
  let k := p * Fintype.card S
  ∑ i : Fin p × S,
    let n := OrbitSize T (OrbitClass p s hp i)
    let n1 := OrbitCount1_idx U T p s hp i
    let theta := (n1 : ℝ) / n
    (n : ℝ) * Real.binEntropy theta

noncomputable def NML (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) : ℝ :=
  let k := p * Fintype.card S
  NLL U T p s hp + (k : ℝ) / 2 * Real.logb 2 T

/-
Definition of ConvergentFrequencies and AsymptoticRate. ConvergentFrequencies states that the empirical frequency of 1s in each orbit class converges to a limit theta_star. AsymptoticRate is the average binary entropy of these limits.
-/
/-- Assumption A1: Convergent orbit-class frequencies. -/
def ConvergentFrequencies (U : Spacetime S) (p : ℕ) (s : S) (hp : p > 0) (theta_star : Fin p × S → ℝ) : Prop :=
  ∀ i : Fin p × S, Filter.Tendsto (fun T => (OrbitCount1_idx U T p s hp i : ℝ) / (OrbitSize T (OrbitClass p s hp i))) Filter.atTop (nhds (theta_star i))

/-- The asymptotic per-site NLL rate lambda_c. -/
noncomputable def AsymptoticRate (p : ℕ) (s : S) (theta_star : Fin p × S → ℝ) : ℝ :=
  (1 / (p * Fintype.card S : ℝ)) * ∑ i : Fin p × S, Real.binEntropy (theta_star i)

/-
Definitions for N_sites, Candidate structure, and IsNMLMinimizer.
-/
/-- The total number of spacetime sites in a window of length T. -/
def N_sites (T : ℕ) : ℕ := T * Fintype.card S

/-- A candidate model is a pair (p, s). -/
structure Candidate (S : Type*) where
  p : ℕ
  s : S
  hp : p > 0

/-- Predicate: c is an NML minimizer at time T among a set of candidates. -/
def IsNMLMinimizer (U : Spacetime S) (Cs : List (Candidate S)) (T : ℕ) (c : Candidate S) : Prop :=
  c ∈ Cs ∧ ∀ c' ∈ Cs, NML U T c.p c.s c.hp ≤ NML U T c'.p c'.s c'.hp

