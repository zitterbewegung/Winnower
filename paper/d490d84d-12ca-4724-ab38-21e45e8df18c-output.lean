/-
Definition of Spacetime and IsRelativePeriodic.
-/
/-- A cellular automaton spacetime is a function from time and space to booleans. -/
def Spacetime (S : Type*) := ℕ → S → Bool

variable {S : Type*} [AddCommGroup S]

/-- The relative-periodic model class B(p, s). -/
def IsRelativePeriodic (B : Spacetime S) (p : ℕ) (s : S) : Prop :=
  ∀ t x, B (t + p) (x + s) = B t x

/-
Definitions for OrbitRel, HammingDistance, Count1, and Count0.
-/
open BigOperators Classical

variable {S : Type*} [AddCommGroup S] [Fintype S] [DecidableEq S]

/-- The orbit relation generated by a model (p, s). -/
def OrbitRel (p : ℕ) (s : S) (pt1 pt2 : ℕ × S) : Prop :=
  ∃ k : ℤ, (pt2.1 : ℤ) = (pt1.1 : ℤ) + k * (p : ℤ) ∧ pt2.2 = pt1.2 + k • s

/-- The Hamming distance between two spacetimes over a window T. -/
def HammingDistance (U B : Spacetime S) (T : ℕ) : ℕ :=
  ∑ t ∈ Finset.range T, ∑ x : S, if U t x ≠ B t x then 1 else 0

/-- The count of 1s in a set of points within a window T. -/
def Count1 (U : Spacetime S) (T : ℕ) (Points : Set (ℕ × S)) : ℕ :=
  ∑ t ∈ Finset.range T, ∑ x : S, if (t, x) ∈ Points ∧ U t x = true then 1 else 0

/-- The count of 0s in a set of points within a window T. -/
def Count0 (U : Spacetime S) (T : ℕ) (Points : Set (ℕ × S)) : ℕ :=
  ∑ t ∈ Finset.range T, ∑ x : S, if (t, x) ∈ Points ∧ U t x = false then 1 else 0

/-
OrbitRel is reflexive.
-/
theorem OrbitRel_refl (p : ℕ) (s : S) : Reflexive (OrbitRel p s) := by
  exact fun x => ⟨ 0, by simp +decide ⟩

/-
OrbitRel is symmetric.
-/
theorem OrbitRel_symm (p : ℕ) (s : S) : Symmetric (OrbitRel p s) := by
  intro x y hxy
  obtain ⟨k, hk⟩ := hxy
  use -k
  simp [hk]

/-
OrbitRel is transitive.
-/
theorem OrbitRel_trans (p : ℕ) (s : S) : Transitive (OrbitRel p s) := by
  -- To prove transitivity, assume there exist integers $k$ and $m$ such that $(t2, x2) = (t1 + k*p, x1 + k*s)$ and $(t3, x3) = (t2 + m*p, x2 + m*s)$.
  intro t1 t2 t3 h1 h2
  obtain ⟨k, hk⟩ := h1
  obtain ⟨m, hm⟩ := h2
  use k + m
  simp [hk, hm];
  exact ⟨ by ring, by rw [ add_assoc, add_smul ] ⟩

/-
Definition of OrbitMap and OrbitClass. OrbitMap maps a spacetime point to a canonical representative in `Fin p × S`. OrbitClass is the fiber of this map.
-/
variable {S : Type*} [AddCommGroup S] [Fintype S] [DecidableEq S]

/-- The canonical representative map for the orbit relation. -/
def OrbitMap (p : ℕ) (s : S) (hp : p > 0) (pt : ℕ × S) : Fin p × S :=
  let t := pt.1
  let x := pt.2
  (⟨t % p, Nat.mod_lt t hp⟩, x - (t / p) • s)

/-- The orbit class corresponding to an index. -/
def OrbitClass (p : ℕ) (s : S) (hp : p > 0) (idx : Fin p × S) : Set (ℕ × S) :=
  { pt | OrbitMap p s hp pt = idx }

/-
Definitions for OrbitCount1_idx, OrbitCount0_idx, and OptimalProjection. OptimalProjection uses majority voting with ties broken to 1.
-/
/-- The count of 1s in an orbit class specified by an index. -/
def OrbitCount1_idx (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) (idx : Fin p × S) : ℕ :=
  Count1 U T (OrbitClass p s hp idx)

/-- The count of 0s in an orbit class specified by an index. -/
def OrbitCount0_idx (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) (idx : Fin p × S) : ℕ :=
  Count0 U T (OrbitClass p s hp idx)

/-- The optimal projection B* constructed by majority vote on orbit classes. Ties broken to 1. -/
def OptimalProjection (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) : Spacetime S :=
  fun t x =>
    let idx := OrbitMap p s hp (t, x)
    let n1 := OrbitCount1_idx U T p s hp idx
    let n0 := OrbitCount0_idx U T p s hp idx
    n1 ≥ n0

/-
The optimal projection is relative-periodic.
-/
theorem OptimalProjection_is_RelativePeriodic (U : Spacetime S) (T : ℕ) (p : ℕ) (s : S) (hp : p > 0) :
  IsRelativePeriodic (OptimalProjection U T p s hp) p s := by
    intro t x; simp +decide [ *, OptimalProjection ] ; ring;
    simp +decide [ OrbitMap, Nat.add_mod, Nat.mod_eq_of_lt hp ];
    simp +decide [ Nat.add_div, hp ] ; ring;
    simp +decide [ add_smul, sub_add_eq_sub_sub ]

