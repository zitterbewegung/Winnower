/-- Definition of eventually exactly periodic background. -/
def EventuallyPeriodic (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) : Prop :=
  ∀ t ≥ T0, ∀ x, U (t + p) (x + s) = U t x
