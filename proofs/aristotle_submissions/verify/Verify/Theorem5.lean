/-
Lemma: If U is eventually periodic, then for any orbit class, the values U(t, x) are eventually constant.
-/
lemma values_eventually_constant_of_eventually_periodic {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) (hp : p > 0)
  (h_eventual : EventuallyPeriodic U p s T0)
  (idx : (Fin p) × X) :
  ∃ c : Bool, ∃ T1 ≥ T0, ∀ t ≥ T1, ∀ x, orbitIndex p s t x hp = idx → U t x = c := by
    -- By definition of orbitIndex, for any t and x, orbitIndex p s t x hp = idx implies that t ≡ idx.1.val (mod p) and x = idx.2 + (t / p) • s.
    have h_orbit_index : ∀ t x, orbitIndex p s t x hp = idx → ∃ m : ℕ, t = idx.1.val + m * p ∧ x = idx.2 + m • s := by
      unfold orbitIndex;
      rintro t x rfl; use t / p; simp +decide [ mul_comm, ← add_assoc, Nat.div_add_mod ] ;
      rw [ Nat.mod_add_div ];
    obtain ⟨c, hc⟩ : ∃ c : Bool, ∀ m : ℕ, m ≥ T0 → U (idx.1.val + m * p) (idx.2 + m • s) = c := by
      use U (idx.1.val + T0 * p) (idx.2 + T0 • s);
      intro m hm; induction hm <;> simp_all +decide [ Nat.succ_mul, ← add_assoc ] ;
      have := h_eventual ( ( idx.1 : ℕ ) + ‹_› * p ) ( by nlinarith ) ( idx.2 + ‹_› • s ) ; simp_all +decide [ add_smul, add_assoc ] ;
    refine' ⟨ c, T0 * p + idx.1.val, _, _ ⟩;
    · nlinarith [ Fin.is_lt idx.1 ];
    · intro t ht x hx; obtain ⟨ m, rfl, rfl ⟩ := h_orbit_index t x hx; exact hc m ( by nlinarith ) ;
