        have h_log_term : Asymptotics.IsBigO Filter.atTop (fun T => Real.logb 2 (T / p : ℝ) - Real.logb 2 (T : ℝ)) (fun _ => (1 : ℝ)) := by
          norm_num [ Real.logb_div, hp.ne' ];
          refine' ⟨ |Real.logb 2 ( 1 / p : ℝ ) - 0|, Filter.eventually_atTop.mpr ⟨ 1, fun x hx => _ ⟩ ⟩ ; norm_num [ Real.logb_div, hp.ne' ];
          rw [ Real.logb_div ( by positivity ) ( by positivity ) ] ; ring_nf ; norm_num [ abs_of_nonneg, Real.logb_nonneg ] ;
        have h_log_term : Asymptotics.IsBigO Filter.atTop (fun T => (Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) - Real.logb 2 (T / p : ℝ)) + (Real.logb 2 (T / p : ℝ) - Real.logb 2 (T : ℝ))) (fun _ => (1 : ℝ)) := by
          exact Asymptotics.IsBigO.add ‹_› ( h_log_term.comp_tendsto tendsto_natCast_atTop_atTop );
        exact h_log_term.congr ( by intros; ring ) ( by intros; ring )
      have h_combined : Asymptotics.IsBigO Filter.atTop (fun T => (count_in_class U p s T idx hp).1 * h_b ((k_inf U p s T0 hp h_eventual idx : ℝ) / (count_in_class U p s T idx hp).1) - (k_inf U p s T0 hp h_eventual idx : ℝ) * Real.logb 2 (T : ℝ)) (fun _ => (1 : ℝ)) := by
        have h_combined : Asymptotics.IsBigO Filter.atTop (fun T => (count_in_class U p s T idx hp).1 * h_b ((k_inf U p s T0 hp h_eventual idx : ℝ) / (count_in_class U p s T idx hp).1) - (k_inf U p s T0 hp h_eventual idx : ℝ) * Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) + (k_inf U p s T0 hp h_eventual idx : ℝ) * (Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) - Real.logb 2 (T : ℝ))) (fun _ => (1 : ℝ)) := by
          exact h_entropic_term.add ( h_log_term.const_mul_left _ );
