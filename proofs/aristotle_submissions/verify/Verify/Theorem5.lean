            exact lt_of_lt_of_le ( by positivity ) hT₂;
          have h_log_term : ∀ᶠ T in Filter.atTop, Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) ≥ Real.logb 2 (T / p : ℝ) - Real.logb 2 2 := by
            filter_upwards [ ‹∀ᶠ T in Filter.atTop, ( count_in_class U p s T idx hp |>.1 : ℝ ) ≥ T / p / 2›, Filter.eventually_gt_atTop 0 ] with T hT₁ hT₂ ; rw [ ge_iff_le ] ; rw [ sub_le_iff_le_add ] ; rw [ Real.logb_le_iff_le_rpow, Real.rpow_add, Real.rpow_logb ] <;> norm_num <;> try positivity;
            · linarith [ show ( T : ℝ ) / p ≥ 0 by positivity ];
