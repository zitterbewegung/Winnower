      have h_log_term : Asymptotics.IsBigO Filter.atTop (fun T => (count_in_class U p s T idx hp).1 - (T : ℝ) / p) (fun _ => (1 : ℝ)) := by
        exact h_count_growth
      have h_log_term : Asymptotics.IsBigO Filter.atTop (fun T => Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) - Real.logb 2 (T : ℝ)) (fun _ => (1 : ℝ)) := by
        have h_log_term : Asymptotics.IsBigO Filter.atTop (fun T => Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) - Real.logb 2 (T / p : ℝ)) (fun _ => (1 : ℝ)) := by
          have h_log_term : ∀ᶠ T in Filter.atTop, (count_in_class U p s T idx hp).1 ≥ (T / p : ℝ) / 2 := by
