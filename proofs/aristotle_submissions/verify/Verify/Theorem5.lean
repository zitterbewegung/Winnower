/-
For a fixed number of minority symbols k, the total entropy n * h_b(k/n) is asymptotically k * log2(n) + O(1).
-/
lemma entropy_asymptotic (k : ℕ) :
  Asymptotics.IsBigO Filter.atTop (fun (n : ℕ) => (n : ℝ) * h_b (k / n) - k * Real.logb 2 n) (fun _ => (1 : Real)) := by
    field_simp;
    by_cases hk : k = 0 <;> simp +decide [ hk, h_b, Real.logb ];
    · exact ⟨ 0, Filter.eventually_atTop.mpr ⟨ 0, fun x hx => by norm_num ⟩ ⟩;
    · -- For large $n$, the expression simplifies to $-k \log k + k + O(1/n)$.
      have h_simplify : ∀ᶠ n : ℕ in Filter.atTop, abs ((n : ℝ) * (-(k / n * (Real.log (k / n) / Real.log 2)) - (1 - k / n) * (Real.log (1 - k / n) / Real.log 2)) - k * (Real.log n / Real.log 2)) ≤ abs (-k * Real.log k / Real.log 2 + k / Real.log 2) + 1 := by
        -- For large $n$, the term $(1 - k/n) \log(1 - k/n)$ can be approximated by $-k/n$.
        have h_approx : Filter.Tendsto (fun n : ℕ => (n : ℝ) * (1 - k / n) * (Real.log (1 - k / n) / Real.log 2)) Filter.atTop (nhds (-k / Real.log 2)) := by
          -- We'll use the fact that $(1 - k/n) \log(1 - k/n)$ converges to $-\frac{k}{n}$ as $n \to \infty$.
          have h_log_approx : Filter.Tendsto (fun n : ℕ => (n : ℝ) * (Real.log (1 - k / n) / Real.log 2)) Filter.atTop (nhds (-k / Real.log 2)) := by
            -- We'll use the fact that $n \log(1 - k/n) \to -k$ as $n \to \infty$.
            have h_log : Filter.Tendsto (fun n : ℕ => (n : ℝ) * Real.log (1 - k / n)) Filter.atTop (nhds (-k)) := by
              -- Let $y = \frac{1}{n}$, so we can rewrite the limit as $\lim_{y \to 0^+} \frac{\log(1 - ky)}{y}$.
              suffices h_log_approx' : Filter.Tendsto (fun y : ℝ => Real.log (1 - k * y) / y) (Filter.map (fun n => 1 / (n : ℝ)) Filter.atTop) (nhds (-k)) by
                exact h_log_approx'.comp ( Filter.map_mono tendsto_natCast_atTop_atTop ) |> fun h => h.congr ( by intros; simp +decide [ div_eq_mul_inv, mul_comm ] );
              simpa [ div_eq_inv_mul ] using HasDerivAt.tendsto_slope_zero_right ( HasDerivAt.log ( HasDerivAt.const_sub 1 ( HasDerivAt.const_mul ( k : ℝ ) ( hasDerivAt_id 0 ) ) ) ( by aesop ) );
            simpa only [ mul_div ] using h_log.div_const _;
          convert h_log_approx.mul ( show Filter.Tendsto ( fun n : ℕ => ( 1 - k / ( n : ℝ ) ) ) Filter.atTop ( nhds 1 ) from by simpa using tendsto_const_nhds.sub ( tendsto_const_nhds.mul tendsto_inverse_atTop_nhds_zero_nat ) ) using 2 <;> ring;
        -- Using the approximation, we can bound the expression.
        have h_bound : Filter.Tendsto (fun n : ℕ => (n : ℝ) * (-(k / n * (Real.log (k / n) / Real.log 2)) - (1 - k / n) * (Real.log (1 - k / n) / Real.log 2)) - k * (Real.log n / Real.log 2)) Filter.atTop (nhds (-k * Real.log k / Real.log 2 + k / Real.log 2)) := by
          have h_bound : Filter.Tendsto (fun n : ℕ => (n : ℝ) * (-(k / n * (Real.log k / Real.log 2)) + k / n * (Real.log n / Real.log 2)) - k * (Real.log n / Real.log 2)) Filter.atTop (nhds (-k * Real.log k / Real.log 2)) := by
            refine' Filter.Tendsto.congr' _ tendsto_const_nhds;
            filter_upwards [ Filter.eventually_gt_atTop 0 ] with n hn using by simp [ div_eq_mul_inv, mul_add, mul_assoc, mul_comm, mul_left_comm, hn.ne' ];
          convert h_bound.add ( h_approx.neg ) using 2 <;> ring;
          by_cases h : ‹_› = 0 <;> simp +decide [ h, mul_assoc, mul_comm, mul_left_comm ] ; ring;
          rw [ Real.log_mul ( by positivity ) ( by positivity ), Real.log_inv ] ; ring;
        have := h_bound.abs.eventually ( ge_mem_nhds <| show |-↑k * Real.log ↑k / Real.log 2 + ↑k / Real.log 2| < |-↑k * Real.log ↑k / Real.log 2 + ↑k / Real.log 2| + 1 by linarith ) ; aesop;
      refine' ⟨ |-k * Real.log k / Real.log 2 + k / Real.log 2| + 1, _ ⟩;
      simp +zetaDelta at *;
      obtain ⟨ a, ha ⟩ := h_simplify; use Max.max a k; intro b hb; specialize ha b ( le_trans ( le_max_left _ _ ) hb ) ; aesop;
/-
Definition of projecting an orbit index from a larger period m*p0 to a smaller period p0.
-/
def projectIndex (p0 : ℕ) (s : X) (m : ℕ) (idx : (Fin (m * p0)) × X) (hp0 : p0 > 0) : (Fin p0) × X :=
  let ⟨j, y⟩ := idx
  ⟨⟨j % p0, Nat.mod_lt _ hp0⟩, y - (j / p0) • s⟩
/-
Correctness of projecting an orbit index from a larger period to a smaller period.
-/
lemma projectIndex_correct (p0 : ℕ) (s : X) (m : ℕ) (t : ℕ) (x : X) (hp0 : p0 > 0) (hm : m > 0) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos hm hp0
  projectIndex p0 s m (orbitIndex p s_p t x hp) hp0 = orbitIndex p0 s t x hp0 := by
    simp +decide [ orbitIndex, projectIndex ];
    rw [ show t / p0 = t / ( m * p0 ) * m + t % ( m * p0 ) / p0 from ?_ ];
    · rw [ add_smul, mul_smul ];
      rw [ sub_sub ];
    · rw [ ← Nat.div_add_mod t ( m * p0 ) ];
      norm_num [ Nat.add_div, Nat.add_mod, Nat.mul_div_assoc, Nat.mul_mod, hp0, hm ];
      split_ifs <;> simp_all +decide [ Nat.mul_assoc, Nat.mul_div_assoc, Nat.mod_eq_of_lt ] ; linarith [ Nat.mod_lt t ( mul_pos hm hp0 ) ] ;
      · linarith [ Nat.mod_lt t hp0 ];
      · exact absurd ‹_› ( not_le_of_gt ( Nat.mod_lt _ ( by positivity ) ) );
      · ring
/-
The counts of total points and ones in an orbit class of the smaller period are the sums of the counts in the corresponding orbit classes of the larger period.
-/
lemma count_sum_of_split (U : Spacetime X) (p0 : ℕ) (s : X) (T : ℕ) (idx0 : (Fin p0) × X) (hp0 : p0 > 0) (m : ℕ) (hm : m > 0) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos hm hp0
  let preimages := Finset.univ.filter (fun idx => projectIndex p0 s m idx hp0 = idx0)
  let (N, K) := count_in_class U p0 s T idx0 hp0
  N = preimages.sum (fun idx => (count_in_class U p s_p T idx hp).1) ∧
  K = preimages.sum (fun idx => (count_in_class U p s_p T idx hp).2) := by
    refine' ⟨ _, _ ⟩;
    · -- By definition of `count_in_class`, we can rewrite the left-hand side as a sum over the preimages.
      have h_sum_preimages : ∑ t ∈ Finset.range T, (Finset.univ.filter (fun x => orbitIndex p0 s t x hp0 = idx0)).card = ∑ t ∈ Finset.range T, ∑ idx ∈ Finset.univ.filter (fun idx => projectIndex p0 s m idx hp0 = idx0), (Finset.univ.filter (fun x => orbitIndex (m * p0) (m • s) t x (Nat.mul_pos hm hp0) = idx)).card := by
        refine' Finset.sum_congr rfl fun t ht => _;
        rw [ ← Finset.card_biUnion ];
        · congr with x;
          simp +decide [ projectIndex_correct p0 s m t x hp0 hm ];
        · exact fun x hx y hy hxy => Finset.disjoint_left.mpr fun z hz1 hz2 => hxy <| by aesop;
      rw [ h_sum_preimages, Finset.sum_comm ];
      exact Finset.sum_congr rfl fun _ _ => rfl;
    · simp +decide only [count_in_class];
      rw [ Finset.sum_comm, Finset.sum_congr rfl ];
      intro t ht;
      rw [ ← Finset.card_biUnion ];
      · congr with x ; simp +decide [ projectIndex_correct ];
        constructor <;> intro h
        all_goals generalize_proofs at *;
        · exact ⟨ _, _, projectIndex_correct p0 s m t x hp0 hm ▸ h.1, rfl, h.2 ⟩;
        · obtain ⟨ a, b, h₁, h₂, h₃ ⟩ := h; have := projectIndex_correct p0 s m t x hp0 hm; aesop;
      · intro x hx y hy hxy; simp_all +decide [ Finset.disjoint_left ] ;
/-
Definition of the eventual value of an orbit class and the number of transient disagreements (k_inf).
-/
noncomputable def eventual_value (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0) (idx : (Fin p) × X) : Bool :=
  Classical.choose (values_eventually_constant_of_eventually_periodic U p s T0 hp h_eventual idx)
noncomputable def k_inf (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0) (idx : (Fin p) × X) : ℕ :=
  let c := eventual_value U p s T0 hp h_eventual idx
  Finset.card (Finset.filter (fun t =>
    if t % p = idx.1 then
      U t (idx.2 + (t / p) • s) ≠ c
    else false
  ) (Finset.range T0))
/-
Consistency of eventual values under period multiplication.
-/
lemma eventual_value_consistent (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ) (hp0 : p0 > 0) (h_eventual : EventuallyPeriodic U p0 s T0) (m : ℕ) (hm : m > 0) (idx : (Fin (m * p0)) × X) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos hm hp0
  have h_eventual_p : EventuallyPeriodic U p s_p T0 := eventually_periodic_multiple U p0 s T0 h_eventual m hm
  eventual_value U p s_p T0 hp h_eventual_p idx = eventual_value U p0 s T0 hp0 h_eventual (projectIndex p0 s m idx hp0) := by
    -- By definition of `eventual_value`, there exist $T1$ and $T2$ such that for all $t \geq T1$, $U(t, x) = eventual\_value U p s_p T0 hp h_eventual_p idx$ and for all $t \geq T2$, $U(t, x) = eventual\_value U p0 s T0 hp0 h_eventual (projectIndex p0 s m idx hp0)$.
    obtain ⟨T1, hT1⟩ : ∃ T1 ≥ T0, ∀ t ≥ T1, ∀ x, orbitIndex (m * p0) (m • s) t x (Nat.mul_pos hm hp0) = idx → U t x = eventual_value U (m * p0) (m • s) T0 (Nat.mul_pos hm hp0) (eventually_periodic_multiple U p0 s T0 h_eventual m hm) idx := by
      have := Classical.choose_spec ( values_eventually_constant_of_eventually_periodic U ( m * p0 ) ( m • s ) T0 ( Nat.mul_pos hm hp0 ) ( eventually_periodic_multiple U p0 s T0 h_eventual m hm ) idx );
      exact this
    obtain ⟨T2, hT2⟩ : ∃ T2 ≥ T0, ∀ t ≥ T2, ∀ x, orbitIndex p0 s t x hp0 = projectIndex p0 s m idx hp0 → U t x = eventual_value U p0 s T0 hp0 h_eventual (projectIndex p0 s m idx hp0) := by
      have := Classical.choose_spec ( values_eventually_constant_of_eventually_periodic U p0 s T0 hp0 h_eventual ( projectIndex p0 s m idx hp0 ) ) ; aesop;
    -- Choose $t$ such that $t \geq \max(T1, T2)$ and $t \equiv idx.1 \pmod{m * p0}$.
    obtain ⟨t, ht⟩ : ∃ t ≥ max T1 T2, t % (m * p0) = idx.1 := by
      use (max T1 T2) * (m * p0) + idx.1.val;
      exact ⟨ by nlinarith [ Nat.zero_le ( max T1 T2 ), mul_pos hm hp0 ], by simp +decide [ Nat.add_mod, Nat.mod_eq_of_lt ( show ( idx.1 : ℕ ) < m * p0 from idx.1.2 ) ] ⟩;
    -- Let $x = idx.2 + (t / (m * p0)) • (m • s)$.
    set x := idx.2 + (t / (m * p0)) • (m • s);
    have hx : orbitIndex (m * p0) (m • s) t x (Nat.mul_pos hm hp0) = idx := by
      unfold orbitIndex; aesop;
    have hx' : orbitIndex p0 s t x hp0 = projectIndex p0 s m idx hp0 := by
      have := projectIndex_correct p0 s m t x hp0 hm; aesop;
    have h_eq : U t x = eventual_value U (m * p0) (m • s) T0 (Nat.mul_pos hm hp0) (eventually_periodic_multiple U p0 s T0 h_eventual m hm) idx ∧ U t x = eventual_value U p0 s T0 hp0 h_eventual (projectIndex p0 s m idx hp0) := by
      exact ⟨ hT1.2 t ( le_trans ( le_max_left _ _ ) ht.1 ) x hx, hT2.2 t ( le_trans ( le_max_right _ _ ) ht.1 ) x hx' ⟩
    aesop
/-
The total number of transient disagreements is invariant under period multiplication.
-/
lemma k_inf_sum_eq (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ) (hp0 : p0 > 0) (h_eventual : EventuallyPeriodic U p0 s T0) (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  have h_eventual_p : EventuallyPeriodic U p s_p T0 := eventually_periodic_multiple U p0 s T0 h_eventual m (Nat.lt_trans Nat.zero_lt_one hm)
  ∑ idx : (Fin p) × X, k_inf U p s_p T0 hp h_eventual_p idx = ∑ idx0 : (Fin p0) × X, k_inf U p0 s T0 hp0 h_eventual idx0 := by
    apply le_antisymm
    all_goals generalize_proofs at *;
    · -- By definition of $k_inf$, we can expand both sides of the inequality.
      have h_expand : ∀ (p : ℕ) (s : X) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0), ∑ idx : (Fin p) × X, k_inf U p s T0 hp h_eventual idx = ∑ t ∈ Finset.range T0, ∑ x : X, if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0 := by
        unfold k_inf;
        intro p s hp h_eventual
        have h_split : ∀ t ∈ Finset.range T0, ∑ x : X, (if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0) = ∑ idx : (Fin p) × X, (if t % p = idx.1 then if U t (idx.2 + (t / p) • s) ≠ eventual_value U p s T0 hp h_eventual idx then 1 else 0 else 0) := by
          intro t ht
          have h_split : ∀ x : X, (if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0) = ∑ idx : (Fin p) × X, (if t % p = idx.1 then if x = idx.2 + (t / p) • s then if U t x ≠ eventual_value U p s T0 hp h_eventual idx then 1 else 0 else 0 else 0) := by
            intro x
            simp [orbitIndex];
            rw [ Finset.sum_eq_single ( ⟨ ⟨ t % p, Nat.mod_lt _ hp ⟩, x - ( t / p ) • s ⟩ : ( Fin p ) × X ) ] <;> simp +decide [ Fin.ext_iff ];
            grind;
          rw [ Finset.sum_congr rfl fun x hx => h_split x, Finset.sum_comm ];
          simp +decide [ Finset.sum_ite ];
        rw [ Finset.sum_congr rfl h_split, Finset.sum_comm ];
        simp +decide [ Finset.sum_ite ];
        simp +decide only [Finset.filter_filter];
      -- By definition of $eventual_value$, we know that for any $t$, the condition $U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp)$ is the same for both periods.
      have h_eventual_value : ∀ (t : ℕ) (x : X), eventual_value U (m * p0) (m • s) T0 (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0) (eventually_periodic_multiple U p0 s T0 h_eventual m (Nat.lt_trans Nat.zero_lt_one hm)) (orbitIndex (m * p0) (m • s) t x (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) = eventual_value U p0 s T0 hp0 h_eventual (orbitIndex p0 s t x hp0) := by
        intro t x; exact (by
        convert eventual_value_consistent U p0 s T0 hp0 h_eventual m ( Nat.lt_trans Nat.zero_lt_one hm ) ( orbitIndex ( m * p0 ) ( m • s ) t x ( Nat.mul_pos ( Nat.lt_trans Nat.zero_lt_one hm ) hp0 ) ) using 1
        generalize_proofs at *; (
        exact congr_arg _ ( projectIndex_correct p0 s m t x hp0 ( Nat.lt_trans Nat.zero_lt_one hm ) ▸ rfl )));
      convert h_expand ( m * p0 ) ( m • s ) ( Nat.mul_pos ( Nat.lt_trans Nat.zero_lt_one hm ) hp0 ) ( eventually_periodic_multiple U p0 s T0 h_eventual m ( Nat.lt_trans Nat.zero_lt_one hm ) ) |> le_of_eq using 2 ; aesop ( simp_config := { singlePass := true } ) ;
    · -- By definition of $k_inf$, we can expand both sides of the inequality.
      have h_expand : ∀ (p : ℕ) (s : X) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0), ∑ idx : (Fin p) × X, k_inf U p s T0 hp h_eventual idx = ∑ t ∈ Finset.range T0, ∑ x : X, if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0 := by
        unfold k_inf;
        intro p s hp h_eventual
        have h_split : ∀ t ∈ Finset.range T0, ∑ x : X, (if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0) = ∑ idx : (Fin p) × X, (if t % p = idx.1 then if U t (idx.2 + (t / p) • s) ≠ eventual_value U p s T0 hp h_eventual idx then 1 else 0 else 0) := by
          intro t ht
          have h_split : ∀ x : X, (if U t x ≠ eventual_value U p s T0 hp h_eventual (orbitIndex p s t x hp) then 1 else 0) = ∑ idx : (Fin p) × X, (if t % p = idx.1 then if x = idx.2 + (t / p) • s then if U t x ≠ eventual_value U p s T0 hp h_eventual idx then 1 else 0 else 0 else 0) := by
            intro x
            simp [orbitIndex];
            rw [ Finset.sum_eq_single ( ⟨ ⟨ t % p, Nat.mod_lt _ hp ⟩, x - ( t / p ) • s ⟩ : ( Fin p ) × X ) ] <;> simp +decide [ Fin.ext_iff ];
            grind;
          rw [ Finset.sum_congr rfl fun x hx => h_split x, Finset.sum_comm ];
          simp +decide [ Finset.sum_ite ];
        rw [ Finset.sum_congr rfl h_split, Finset.sum_comm ];
        simp +decide [ Finset.sum_ite ];
        simp +decide only [Finset.filter_filter];
      rw [ h_expand p0 s hp0 h_eventual, h_expand ( m * p0 ) ( m • s ) ( Nat.mul_pos ( pos_of_gt hm ) hp0 ) ( eventually_periodic_multiple U p0 s T0 h_eventual m hm.le ) ];
      refine' Finset.sum_le_sum fun t ht => Finset.sum_le_sum fun x hx => _;
      rw [ eventual_value_consistent ];
      rw [ projectIndex_correct ];
      · linarith;
      · exact hp0;
      · assumption;
      · linarith
/-
The NLL term for an orbit class depends only on the number of transient disagreements k_inf.
-/
lemma nll_term_eq_k_inf (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0) (idx : (Fin p) × X) (T : ℕ) (hT : T ≥ T0) :
  let (n, k) := count_in_class U p s T idx hp
  let k_i := k_inf U p s T0 hp h_eventual idx
  (if n = 0 then (0 : ℝ) else (n : ℝ) * h_b ((k : ℝ) / (n : ℝ))) = (if n = 0 then (0 : ℝ) else (n : ℝ) * h_b ((k_i : ℝ) / (n : ℝ))) := by
    -- Let $c$ be the eventual value of the orbit class.
    set c := eventual_value U p s T0 hp h_eventual idx;
    -- For $t \geq T0$, $U(t, x) = c$ for all $x$ in the orbit class.
    have h_const : ∀ t ≥ T0, ∀ x, orbitIndex p s t x hp = idx → U t x = c := by
      have := Classical.choose_spec ( values_eventually_constant_of_eventually_periodic U p s T0 hp h_eventual idx );
      obtain ⟨ T1, hT1, h ⟩ := this; intro t ht x hx; by_cases hT : t < T1 <;> simp_all +decide ;
      · convert h ( t + p * ( T1 - t ) ) ( by nlinarith [ Nat.sub_add_cancel hT.le ] ) ( x + ( T1 - t ) • s ) _ using 1;
        · induction' T1 - t with k hk <;> simp_all +decide [ Nat.mul_succ, ← add_assoc ];
          convert h_eventual ( t + p * k ) ( by nlinarith ) ( x + k • s ) |> Eq.symm using 1 ; simp +decide [ add_smul, add_assoc ];
        · induction' T1 - t with k hk <;> simp_all +decide [ Nat.mul_succ, ← add_assoc ];
          convert orbitIndex_add_period p s ( t + p * k ) ( x + k • s ) hp using 1 ; simp +decide [ add_smul, add_assoc ];
          exact hk.symm;
      · rfl;
    -- For $t < T0$, $U(t, x) = 1 - c$ if and only if $U(t, x)$ is in the orbit class and $U(t, x) \neq c$.
    have h_disagreements : Finset.sum (Finset.range T) (fun t => Finset.card (Finset.filter (fun x => orbitIndex p s t x hp = idx ∧ U t x = 1 - c) Finset.univ)) = k_inf U p s T0 hp h_eventual idx := by
      have h_disagreements : ∀ t < T0, Finset.card (Finset.filter (fun x => orbitIndex p s t x hp = idx ∧ U t x = 1 - c) Finset.univ) = if t % p = idx.1 ∧ U t (idx.2 + (t / p) • s) = 1 - c then 1 else 0 := by
        intro t ht; split_ifs <;> simp_all +decide [ Fin.ext_iff, orbitIndex ] ;
        · rw [ Finset.card_eq_one ] ; use idx.2 + ( t / p ) • s ; ext x ; aesop;
        · intro x hx; contrapose! hx; aesop;
      rw [ ← Finset.sum_subset ( Finset.range_mono hT ) ];
      · rw [ Finset.sum_congr rfl fun t ht => h_disagreements t ( Finset.mem_range.mp ht ) ] ; simp +decide [ k_inf ] ; ring;
        congr! 2;
        ext; simp [c];
        cases eventual_value U p s T0 hp h_eventual idx <;> simp +decide [ * ];
        · aesop;
        · aesop;
      · simp +contextual [ Finset.ext_iff, h_const ];
        cases c <;> simp +decide;
    -- For $t < T0$, $U(t, x) = c$ if and only if $U(t, x)$ is in the orbit class and $U(t, x) = c$.
    have h_agreements : Finset.sum (Finset.range T) (fun t => Finset.card (Finset.filter (fun x => orbitIndex p s t x hp = idx ∧ U t x = c) Finset.univ)) = (count_in_class U p s T idx hp).1 - k_inf U p s T0 hp h_eventual idx := by
      rw [ ← h_disagreements, Nat.sub_eq_of_eq_add ];
      rw [ ← Finset.sum_add_distrib, count_in_class ];
      cases c <;> simp +decide [ *, Finset.filter_or ];
      · refine' Finset.sum_congr rfl fun t ht => _;
        rw [ Finset.card_filter, Finset.card_filter, Finset.card_filter ];
        rw [ ← Finset.sum_add_distrib ] ; congr ; ext x ; cases U t x <;> simp +decide [ * ] ;
      · refine' Finset.sum_congr rfl fun t ht => _;
        rw [ Finset.card_filter, Finset.card_filter, Finset.card_filter ];
        rw [ ← Finset.sum_add_distrib ] ; congr ; ext x ; by_cases hx : U t x <;> simp +decide [ hx ] ;
    -- By definition of $k$, we know that $k = \sum_{t=0}^{T-1} \sum_{x \in \text{orbit class}} U(t, x)$.
    have h_k : (count_in_class U p s T idx hp).2 = Finset.sum (Finset.range T) (fun t => Finset.card (Finset.filter (fun x => orbitIndex p s t x hp = idx ∧ U t x = true) Finset.univ)) := by
      exact?;
    by_cases hc : c <;> simp_all +decide [ Finset.sum_ite ];
    · rw [ Nat.cast_sub ];
      · unfold h_b; ring;
        grind;
      · rw [ ← h_disagreements ];
        exact Finset.sum_le_sum fun i hi => Finset.card_le_card fun x hx => by aesop;
    · rw [ ← h_disagreements ];
      norm_num [ Finset.sum_filter ];
      congr! 3
/-
The NLL grows asymptotically as `K * log2(T) + O(1)`, where `K` is the total number of transient disagreements.
-/
lemma nll_asymptotic (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ) (hp : p > 0) (h_eventual : EventuallyPeriodic U p s T0) :
  Asymptotics.IsBigO Filter.atTop (fun T => NLL U p s T hp - (∑ idx : (Fin p) × X, (k_inf U p s T0 hp h_eventual idx : ℝ)) * Real.logb 2 T) (fun T => (1 : Real)) := by
    -- Apply the lemma `nll_term_eq_k_inf` to each term in the sum.
    have h_term : ∀ idx : (Fin p) × X, (fun T => (if (count_in_class U p s T idx hp).1 = 0 then (0 : ℝ) else (count_in_class U p s T idx hp).1 * h_b ((k_inf U p s T0 hp h_eventual idx : ℝ) / (count_in_class U p s T idx hp).1)) - (k_inf U p s T0 hp h_eventual idx : ℝ) * Real.logb 2 (T : ℝ)) =O[Filter.atTop] (fun _ => 1 : ℕ → ℝ) := by
      intro idx
      have h_count_growth : Asymptotics.IsBigO Filter.atTop (fun T => (count_in_class U p s T idx hp).1 - (T : ℝ) / p) (fun _ => (1 : ℝ)) := by
        -- The count_in_class is the sum of the number of points in each time step, which is T/p plus some error term.
        have h_count_in_class : ∀ T ≥ T0, (count_in_class U p s T idx hp).1 = ∑ t ∈ Finset.range T, (if t % p = idx.1.val then 1 else 0) := by
          intro T hT
          simp [count_in_class, orbitIndex];
          rw [ Finset.card_filter ];
          refine' Finset.sum_congr rfl fun i hi => _;
          split_ifs <;> simp_all +decide [ Fin.ext_iff, Prod.ext_iff ];
          exact Finset.card_eq_one.mpr ⟨ idx.2 + ( i / p ) • s, by ext x; simp +decide [ sub_eq_iff_eq_add ] ⟩;
        -- The sum of the number of points in each time step is equal to the number of times the condition holds, which is T/p plus some error term.
        have h_sum : ∀ T ≥ T0, (∑ t ∈ Finset.range T, (if t % p = idx.1.val then 1 else 0)) = (T / p : ℕ) + (if idx.1.val < T % p then 1 else 0) := by
          intro T hT
          have h_sum : Finset.card (Finset.filter (fun t => t % p = idx.1.val) (Finset.range T)) = Finset.card (Finset.image (fun t => p * t + idx.1.val) (Finset.range (T / p + (if idx.1.val < T % p then 1 else 0)))) := by
            congr with t ; simp +decide [ Nat.mod_eq_of_lt ];
            constructor <;> intro h;
            · use t / p;
              exact ⟨ by split_ifs <;> nlinarith [ Nat.mod_add_div t p, Nat.mod_add_div T p, Nat.mod_lt t hp, Nat.mod_lt T hp ], by linarith [ Nat.mod_add_div t p ] ⟩;
            · rcases h with ⟨ a, ha, rfl ⟩ ; split_ifs at ha <;> simp_all +decide [ Nat.mod_eq_of_lt ] ; nlinarith [ Nat.div_add_mod T p, Nat.mod_lt T hp ] ;
              nlinarith [ Nat.div_mul_le_self T p, Nat.mod_add_div T p, Fin.is_lt idx.1 ];
          rw [ Finset.card_image_of_injective _ fun x y hxy => by nlinarith ] at h_sum ; aesop;
        rw [ Asymptotics.isBigO_iff ];
        use 2 + 1 / p; filter_upwards [ Filter.eventually_ge_atTop T0 ] with T hT; rw [ h_count_in_class T hT, h_sum T hT ] ; norm_num [ abs_le ] ; ring_nf ;
        field_simp;
        split_ifs <;> constructor <;> nlinarith [ show ( p : ℝ ) ≥ 1 by exact_mod_cast hp, show ( T : ℝ ) ≥ p * ( T / p : ℕ ) by exact_mod_cast Nat.mul_div_le _ _, show ( T : ℝ ) < p * ( T / p : ℕ ) + p by exact_mod_cast by linarith [ Nat.div_add_mod T p, Nat.mod_lt T hp ] ] ;
