/-- Theorem 5(i): The per-site NLL rates are equal to 0. -/
theorem theorem_5_i {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) (fun T : ℕ => (T : Real)) ∧
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U p0 s T hp0) (fun T : ℕ => (T : Real)) := by
  have hp : m * p0 > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  constructor
  · -- Part 1: p = m * p0
    have h_eventual_p : EventuallyPeriodic U (m * p0) (m • s) T0 := by
      apply eventually_periodic_multiple U p0 s T0 h_eventual m (Nat.lt_trans Nat.zero_lt_one hm)
    obtain ⟨C, hC⟩ := nll_growth_bound U (m * p0) (m • s) T0 hp h_eventual_p
    have h_bigO : Asymptotics.IsBigO Filter.atTop (fun T => NLL U (m * p0) (m • s) T hp) (fun T : ℕ => Real.log (T + 1)) := by
      rw [Asymptotics.isBigO_iff]
      use C + |C| + 1
      filter_upwards [Filter.eventually_ge_atTop T0] with T hT
      rw [Real.norm_eq_abs, abs_of_nonneg (by
      -- Since each term in the sum is non-negative, the entire sum is non-negative.
      have h_nonneg : ∀ (idx : (Fin (m * p0)) × X), 0 ≤ (let (n, k) := count_in_class U (m * p0) (m • s) T idx hp; if n = 0 then 0 else n * h_b ((k : ℝ) / n)) := by
        -- Since $h_b(x)$ is non-negative for all $x \in [0, 1]$, and $n$ is non-negative, their product is non-negative.
        have h_h_b_nonneg : ∀ x : ℝ, 0 ≤ x → x ≤ 1 → 0 ≤ h_b x := by
          intro x hx₁ hx₂; unfold h_b; split_ifs <;> norm_num;
          rw [ Real.logb, Real.logb ];
          field_simp;
          nlinarith [ Real.log_le_sub_one_of_pos ( show 0 < 1 - x by exact sub_pos.mpr ( lt_of_le_of_ne hx₂ ( by tauto ) ) ), Real.log_le_sub_one_of_pos ( show 0 < x by exact lt_of_le_of_ne hx₁ ( by tauto ) ) ];
        intro idx
        simp [count_in_class];
        split_ifs <;> [ exact le_rfl; exact mul_nonneg ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ( h_h_b_nonneg _ ( div_nonneg ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ) ( div_le_one_of_le₀ ( Finset.sum_le_sum fun _ _ => mod_cast Finset.card_mono <| fun x hx => by aesop ) ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ) ) ];
      exact Finset.sum_nonneg fun _ _ => h_nonneg _)]
      specialize hC T hT
      cases abs_cases C <;> simp +decide [ * ];
      · by_cases h_log : Real.log (T + 1) ≥ 1;
        · rw [ abs_of_nonneg ( Real.log_nonneg ( by linarith ) ) ] ; nlinarith;
        · rw [ abs_of_nonneg ( Real.log_nonneg ( by linarith ) ) ];
          rcases T with ( _ | _ | T ) <;> norm_num at *;
          · unfold NLL; aesop;
          · nlinarith [ Real.log_two_gt_d9, show ( NLL U ( m * p0 ) ( m • s ) 1 hp : ℝ ) ≤ 0 from by
                                              unfold NLL;
                                              unfold count_in_class; simp +decide [ Finset.sum_range_succ' ] ;
                                              simp +decide [ Finset.sum_ite, orbitIndex ];
                                              simp +decide [ Finset.filter_eq', Finset.filter_and ];
                                              refine' Finset.sum_nonpos fun x _ => _;
                                              by_cases hx : U 0 x <;> simp +decide [ hx, h_b ] ];
          · exact False.elim <| h_log.not_le <| Real.le_log_iff_exp_le ( by positivity ) |>.2 <| by exact Real.exp_one_lt_d9.le.trans <| by norm_num; linarith;
      · nlinarith [ abs_nonneg ( Real.log ( T + 1 ) ), Real.log_nonneg ( by linarith : ( T : ℝ ) + 1 ≥ 1 ) ]
    have h_littleO : Asymptotics.IsLittleO Filter.atTop (fun T : ℕ => Real.log (T + 1)) (fun T : ℕ => (T : Real)) := by
      -- To show that Real.log (T + 1) is little-o of T, we can use the fact that the limit of Real.log T / T as T approaches infinity is 0.
      have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => Real.log T / T) Filter.atTop (nhds 0) := by
        -- Let $y = \frac{1}{x}$, so we can rewrite the limit as $\lim_{y \to 0^+} y \log(1/y)$.
        suffices h_log_recip : Filter.Tendsto (fun y : ℝ => y * Real.log (1 / y)) (Filter.map (fun x => 1 / x) Filter.atTop) (nhds 0) by
          exact h_log_recip.congr ( by simp +contextual [ div_eq_inv_mul ] );
        norm_num +zetaDelta at *;
        exact tendsto_nhdsWithin_of_tendsto_nhds ( by simpa using Real.continuous_mul_log.neg.tendsto 0 );
      rw [ Asymptotics.isLittleO_iff_tendsto' ] <;> norm_num;
      · have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => Real.log (T + 1) / T) Filter.atTop (nhds 0) := by
          have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => (Real.log T + Real.log (1 + 1 / T)) / T) Filter.atTop (nhds 0) := by
            simpa [ add_div ] using h_log_div_T_zero.add ( Filter.Tendsto.div_atTop ( Filter.Tendsto.log ( tendsto_const_nhds.add ( tendsto_inv_atTop_zero ) ) ( by norm_num ) ) Filter.tendsto_id );
          refine h_log_div_T_zero.congr' ( by filter_upwards [ Filter.eventually_gt_atTop 0 ] with T hT using by rw [ one_add_div hT.ne', Real.log_div ] <;> ring <;> positivity );
        exact h_log_div_T_zero.comp tendsto_natCast_atTop_atTop;
      · exact ⟨ 1, by intros; linarith ⟩
    exact Asymptotics.IsBigO.trans_isLittleO h_bigO h_littleO
  · -- Part 2: p0
    obtain ⟨C, hC⟩ := nll_growth_bound U p0 s T0 hp0 h_eventual
    have h_bigO : Asymptotics.IsBigO Filter.atTop (fun T => NLL U p0 s T hp0) (fun T : ℕ => Real.log (T + 1)) := by
      rw [Asymptotics.isBigO_iff]
      use C + |C| + 1
      filter_upwards [Filter.eventually_ge_atTop T0] with T hT
      rw [Real.norm_eq_abs, abs_of_nonneg (by
      -- Each term in the sum is non-negative because $h_b(\theta)$ is non-negative for any $\theta \in [0, 1]$.
      have h_nonneg : ∀ idx : (Fin p0) × X, 0 ≤ (let (n, k) := count_in_class U p0 s T idx hp0; if n = 0 then 0 else n * h_b (k / n)) := by
        -- Since $h_b(\theta)$ is non-negative for any $\theta \in [0, 1]$, and $n$ is non-negative, their product is also non-negative.
        have h_nonneg : ∀ theta : ℝ, 0 ≤ theta ∧ theta ≤ 1 → 0 ≤ h_b theta := by
          unfold h_b;
          -- Since $\log_2(\theta)$ and $\log_2(1-\theta)$ are negative for $0 < \theta < 1$, their product with $-\theta$ and $-(1-\theta)$ respectively will be positive.
          intros theta htheta
          by_cases htheta0 : theta = 0 ∨ theta = 1;
          · aesop;
          · split_ifs ; nlinarith [ show Real.logb 2 theta ≤ 0 from Real.logb_nonpos ( by norm_num ) ( by linarith ) ( by linarith ), show Real.logb 2 ( 1 - theta ) ≤ 0 from Real.logb_nonpos ( by norm_num ) ( by linarith ) ( by linarith ) ];
        intro idx
        simp [count_in_class];
        split_ifs <;> norm_num;
        exact mul_nonneg ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ( h_nonneg _ ⟨ div_nonneg ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ), div_le_one_of_le₀ ( Finset.sum_le_sum fun _ _ => mod_cast Finset.card_le_card fun _ => by aesop ) ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ⟩ );
      exact Finset.sum_nonneg fun _ _ => h_nonneg _)]
      specialize hC T hT
      cases abs_cases C <;> simp +decide [ * ];
      · by_cases h_log : Real.log (T + 1) ≥ 1;
        · rw [ abs_of_nonneg ( by positivity ) ] ; nlinarith;
        · rw [ abs_of_nonneg ( Real.log_nonneg ( by linarith ) ) ];
          contrapose! h_log;
          rcases T with ( _ | _ | T ) <;> norm_num at *;
          · unfold NLL at h_log ; aesop;
          · have hNLL_zero : NLL U p0 s 1 hp0 = 0 := by
              unfold NLL; simp +decide [ Finset.sum_range_succ' ] ;
              unfold count_in_class; simp +decide [ Finset.sum_range_succ' ] ;
              unfold orbitIndex; simp +decide [ Finset.sum_ite ] ;
              simp +decide [ Finset.filter_eq', Finset.filter_and ];
              refine' Finset.sum_eq_zero fun x _ => _ ; by_cases hx : U 0 x = Bool.true <;> simp +decide [ hx ] ;
              · unfold h_b; simp +decide ;
              · unfold h_b; simp +decide ;
            nlinarith [ Real.log_pos one_lt_two ];
          · exact Real.le_log_iff_exp_le ( by linarith ) |>.2 ( by exact Real.exp_one_lt_d9.le.trans ( by norm_num; linarith ) );
      · exact le_trans hC ( by nlinarith [ abs_of_nonneg ( Real.log_nonneg ( by linarith : ( T:ℝ ) + 1 ≥ 1 ) ), Real.log_nonneg ( by linarith : ( T:ℝ ) + 1 ≥ 1 ) ] )
    have h_littleO : Asymptotics.IsLittleO Filter.atTop (fun T : ℕ => Real.log (T + 1)) (fun T : ℕ => (T : Real)) := by
      -- To show that Real.log (T + 1) is little-o of T, we can use the fact that the limit of Real.log T / T as T approaches infinity is 0.
      have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => Real.log T / T) Filter.atTop (nhds 0) := by
        -- Let $y = \frac{1}{x}$, so we can rewrite the limit as $\lim_{y \to 0^+} y \log(1/y)$.
        suffices h_log_recip : Filter.Tendsto (fun y : ℝ => y * Real.log (1 / y)) (Filter.map (fun x => 1 / x) Filter.atTop) (nhds 0) by
          exact h_log_recip.congr ( by simp +contextual [ div_eq_inv_mul ] );
