      filter_upwards [ Filter.eventually_gt_atTop 0 ] with T hT using by aesop;) (by
      rfl);
    have h_sum : (fun T => (∑ idx : (Fin p) × X, (if (count_in_class U p s T idx hp).1 = 0 then (0 : ℝ) else (count_in_class U p s T idx hp).1 * h_b ((k_inf U p s T0 hp h_eventual idx : ℝ) / (count_in_class U p s T idx hp).1))) - (∑ idx : (Fin p) × X, (k_inf U p s T0 hp h_eventual idx : ℝ)) * Real.logb 2 (T : ℝ)) =O[Filter.atTop] (fun _ => 1 : ℕ → ℝ) := by
      simpa [ Finset.sum_mul _ _ _ ] using Asymptotics.IsBigO.sum fun i _ => h_term i;
    refine' h_sum.congr' _ _;
    · filter_upwards [ Filter.eventually_gt_atTop T0 ] with T hT;
      simp +decide [ NLL, nll_term_eq_k_inf U p s T0 hp h_eventual _ T hT.le ];
    · rfl
/-
Theorem 5(ii): The NLL difference satisfies NLL(p, T) - NLL(p₀, T) = O(1).
-/
theorem theorem_5_ii {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  Asymptotics.IsBigO Filter.atTop (fun T => NLL U p s_p T hp - NLL U p0 s T hp0) (fun T => (1 : Real)) := by
    -- By Lemma `nll_asymptotic`, both `NLL(U, p, T)` and `NLL(U, p0, T)` are asymptotically `K * log2(T) + O(1)`.
    have h_asymptotic : ∀ p s hp h_eventual, Asymptotics.IsBigO Filter.atTop (fun T => NLL U p s T hp - (∑ idx : (Fin p) × X, (k_inf U p s T0 hp h_eventual idx : ℝ)) * Real.logb 2 T) (fun T => (1 : ℝ)) := by
      exact?;
    have h_coeff : (∑ idx : (Fin (m * p0)) × X, (k_inf U (m * p0) (m • s) T0 (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0) (eventually_periodic_multiple U p0 s T0 h_eventual m (Nat.lt_trans Nat.zero_lt_one hm)) idx : ℝ)) = (∑ idx0 : (Fin p0) × X, (k_inf U p0 s T0 hp0 h_eventual idx0 : ℝ)) := by
      exact_mod_cast k_inf_sum_eq U p0 s T0 hp0 h_eventual m hm;
    convert Asymptotics.IsBigO.sub ( h_asymptotic ( m * p0 ) ( m • s ) ( Nat.mul_pos ( Nat.lt_trans Nat.zero_lt_one hm ) hp0 ) ( eventually_periodic_multiple U p0 s T0 h_eventual m ( Nat.lt_trans Nat.zero_lt_one hm ) ) ) ( h_asymptotic p0 s hp0 h_eventual ) using 2 ; aesop
/-
Definition of COMP and its asymptotic behavior.
-/
noncomputable def COMP (U : Spacetime X) (p : ℕ) (s : X) (T : ℕ) (hp : p > 0) : Real :=
  Finset.univ.sum (fun (idx : (Fin p) × X) =>
    let (n, _) := count_in_class U p s T idx hp
    if n = 0 then 0 else 0.5 * Real.logb 2 n
  )
lemma comp_asymptotic (U : Spacetime X) (p : ℕ) (s : X) (hp : p > 0) :
  Asymptotics.IsBigO Filter.atTop (fun T => COMP U p s T hp - (p * Fintype.card X : ℝ) / 2 * Real.logb 2 T) (fun T => (1 : Real)) := by
    -- Let's simplify the expression for the complexity term.
    have h_simplify : ∀ T ≥ p, COMP U p s T hp = (p * Fintype.card X / 2) * Real.logb 2 T + (∑ idx : (Fin p) × X, 0.5 * Real.logb 2 ((count_in_class U p s T idx hp).1 / T)) := by
      unfold COMP;
      intro T hT
      have h_count : ∀ idx : (Fin p) × X, (count_in_class U p s T idx hp).1 = T / p + (if (idx.1 : ℕ) < T % p then 1 else 0) := by
        intro idx
        unfold count_in_class
        simp [orbitIndex];
        -- Let's simplify the sum by considering the condition $(⟨x % p, ⋯⟩, x_1 - (x / p) • s) = idx$.
        have h_sum : ∑ x ∈ Finset.range T, (Finset.card (Finset.filter (fun x_1 => (⟨x % p, Nat.mod_lt _ hp⟩, x_1 - (x / p) • s) = idx) Finset.univ)) = ∑ x ∈ Finset.range T, (if x % p = idx.1.val then 1 else 0) := by
          refine' Finset.sum_congr rfl fun x hx => _;
          split_ifs <;> simp_all +decide [ Fin.ext_iff, Prod.ext_iff ];
          exact Finset.card_eq_one.mpr ⟨ idx.2 + ( x / p ) • s, by ext; simp +decide [ sub_eq_iff_eq_add ] ⟩;
        simp_all +decide [ Finset.sum_ite ];
        have h_card : Finset.filter (fun x => x % p = idx.1.val) (Finset.range T) = Finset.image (fun k => k * p + idx.1.val) (Finset.range (T / p + if idx.1.val < T % p then 1 else 0)) := by
          ext x; simp [Finset.mem_image];
          constructor;
          · intro hx
            use x / p;
            exact ⟨ by split_ifs <;> nlinarith [ Nat.mod_add_div x p, Nat.mod_add_div T p, Nat.mod_lt x hp, Nat.mod_lt T hp ], by linarith [ Nat.mod_add_div x p ] ⟩;
          · rintro ⟨ a, ha, rfl ⟩ ; split_ifs at ha <;> simp_all +decide [ Nat.mod_eq_of_lt ] ; nlinarith [ Nat.div_add_mod T p, Nat.mod_lt T hp ] ;
            nlinarith [ Nat.div_mul_le_self T p, Fin.is_lt idx.1 ];
        rw [ h_card, Finset.card_image_of_injective ] <;> simp +decide [ Function.Injective, hp.ne' ];
      rw [ Finset.sum_congr rfl fun x hx => ?_ ];
      any_goals exact fun x => 0.5 * Real.logb 2 ( ( count_in_class U p s T x hp |>.1 ) / T ) + 0.5 * Real.logb 2 T;
      · simp +decide [ Finset.sum_add_distrib, Finset.mul_sum _ _ _, Finset.sum_mul, h_count ] ; ring;
      · by_cases h : ( count_in_class U p s T x hp |>.1 ) = 0 <;> simp +decide [ h, Real.logb_div ];
        · exact absurd h ( by rw [ h_count ] ; exact ne_of_gt ( add_pos_of_pos_of_nonneg ( Nat.div_pos ( by linarith ) hp ) ( Nat.zero_le _ ) ) );
        · rw [ Real.logb_div ( by positivity ) ( by norm_cast; linarith ) ] ; ring;
    -- Since each count_in_class U p s T idx hp.1 is asymptotically equivalent to T/p, the ratio (count_in_class U p s T idx hp.1) / T is asymptotically equivalent to 1/p.
    have h_ratio : ∀ idx : (Fin p) × X, Filter.Tendsto (fun T : ℕ => (count_in_class U p s T idx hp).1 / (T : ℝ)) Filter.atTop (nhds (1 / p)) := by
      intro idx
      have h_count : ∀ T ≥ p, (count_in_class U p s T idx hp).1 = Finset.card (Finset.filter (fun t => t % p = idx.1.val) (Finset.range T)) := by
        intro T hT
        simp [count_in_class, orbitIndex];
        rw [ Finset.card_filter ];
        refine' Finset.sum_congr rfl fun i hi => _;
        split_ifs <;> simp_all +decide [ Fin.ext_iff, Prod.ext_iff ];
        exact Finset.card_eq_one.mpr ⟨ idx.2 + ( i / p ) • s, by ext x; simp +decide [ sub_eq_iff_eq_add ] ⟩
      simp_all +decide [ Finset.card_range, Nat.div_eq_of_lt ];
      -- The number of integers $t$ in the range $0$ to $T-1$ such that $t \equiv idx.1 \pmod{p}$ is approximately $T/p$.
      have h_card_approx : ∀ T ≥ p, (Finset.card (Finset.filter (fun t => t % p = idx.1.val) (Finset.range T))) ≤ T / p + 1 ∧ (Finset.card (Finset.filter (fun t => t % p = idx.1.val) (Finset.range T))) ≥ T / p := by
        intro T hT
        have h_card_approx : Finset.card (Finset.filter (fun t => t % p = idx.1.val) (Finset.range T)) ≤ Finset.card (Finset.image (fun t => t * p + idx.1.val) (Finset.range (T / p + 1))) := by
          refine Finset.card_mono ?_;
          exact fun x hx => Finset.mem_image.mpr ⟨ x / p, Finset.mem_range.mpr ( Nat.lt_succ_of_le ( Nat.div_le_div_right ( Finset.mem_range_le ( Finset.mem_filter.mp hx |>.1 ) ) ) ), by linarith [ Nat.mod_add_div x p, Finset.mem_filter.mp hx |>.2 ] ⟩;
        refine' ⟨ h_card_approx.trans ( Finset.card_image_le.trans ( by simp +decide ) ), _ ⟩;
        refine' le_trans _ ( Finset.card_mono <| show Finset.image ( fun t => t * p + idx.1 ) ( Finset.range ( T / p ) ) ⊆ Finset.filter ( fun t => t % p = idx.1 ) ( Finset.range T ) from _ );
        · rw [ Finset.card_image_of_injective ] <;> norm_num [ Function.Injective, hp.ne' ];
        · simp +decide [ Finset.subset_iff ];
          exact fun a ha => ⟨ by nlinarith [ Nat.div_mul_le_self T p, Fin.is_lt idx.1 ], Nat.mod_eq_of_lt ( Fin.is_lt idx.1 ) ⟩;
      -- Using the approximation, we can bound the ratio.
      have h_ratio_bound : ∀ T ≥ p, abs ((count_in_class U p s T idx hp).1 / (T : ℝ) - 1 / p) ≤ 2 / (T : ℝ) := by
        intro T hT; rw [ h_count T hT ] ; rw [ abs_le ] ; constructor <;> ring_nf <;> norm_num [ hp.ne' ];
        · field_simp;
          rw [ le_div_iff₀ ] <;> norm_cast <;> nlinarith [ h_card_approx T hT, Nat.div_add_mod T p, Nat.mod_lt T hp ];
        · field_simp;
          rw [ div_add_one, div_le_div_iff_of_pos_right ] <;> norm_cast <;> nlinarith [ h_card_approx T hT, Nat.div_mul_le_self T p, Nat.div_add_mod T p, Nat.mod_lt T hp ];
      exact tendsto_iff_norm_sub_tendsto_zero.mpr ( squeeze_zero_norm' ( Filter.eventually_atTop.mpr ⟨ p, fun T hT => by simpa using h_ratio_bound T hT ⟩ ) ( tendsto_const_nhds.div_atTop tendsto_natCast_atTop_atTop ) ) |> fun h => h.trans ( by simp +decide );
    -- Since the logarithm function is continuous, the sum of the logarithms of the ratios is also asymptotically equivalent to the sum of the logarithms of 1/p.
    have h_log_ratio : Filter.Tendsto (fun T : ℕ => ∑ idx : (Fin p) × X, 0.5 * Real.logb 2 ((count_in_class U p s T idx hp).1 / T)) Filter.atTop (nhds (∑ idx : (Fin p) × X, 0.5 * Real.logb 2 (1 / p))) := by
      exact tendsto_finset_sum _ fun _ _ => Filter.Tendsto.mul tendsto_const_nhds ( Filter.Tendsto.div_const ( Filter.Tendsto.log ( h_ratio _ ) ( by positivity ) ) _ );
    rw [ Asymptotics.isBigO_iff ];
    obtain ⟨ c, hc ⟩ := h_log_ratio.abs.bddAbove_range;
    exact ⟨ c, Filter.eventually_atTop.mpr ⟨ p, fun T hT => by rw [ h_simplify T hT ] ; simpa using hc ⟨ T, rfl ⟩ ⟩ ⟩
/-
Theorem 5(iii): The NML score difference satisfies NML(p, T) - NML(p₀, T) = (m-1)·k_{p₀}/2 · log₂ T + O(1).
-/
theorem theorem_5_iii {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  let k_p0 := (p0 * Fintype.card X : ℝ)
  Asymptotics.IsBigO Filter.atTop (fun T => NML U p s_p T hp - NML U p0 s T hp0 - (m - 1 : ℝ) * k_p0 / 2 * Real.logb 2 T) (fun T => (1 : Real)) := by
    -- By combining the results from the previous lemmas, we can conclude the proof.
    have h_combined : (fun T => (NLL U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) - (NLL U p0 s T hp0)) =O[Filter.atTop] (fun T : ℕ => 1 : ℕ → ℝ) ∧ (fun T => (COMP U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) - (COMP U p0 s T hp0) - ((m - 1) * (p0 * Fintype.card X) / 2 : ℝ) * Real.logb 2 (T : ℝ)) =O[Filter.atTop] (fun T : ℕ => 1 : ℕ → ℝ) := by
      constructor;
      · exact?;
      · -- Apply the lemma comp_asymptotic to both p and p0 to express the differences in terms of the logarithmic terms.
        have h_comp_diff : (fun T => COMP U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0) - (m * p0 * Fintype.card X / 2 : ℝ) * Real.logb 2 T) =O[Filter.atTop] (fun T : ℕ => 1 : ℕ → ℝ) ∧ (fun T => COMP U p0 s T hp0 - (p0 * Fintype.card X / 2 : ℝ) * Real.logb 2 T) =O[Filter.atTop] (fun T : ℕ => 1 : ℕ → ℝ) := by
          apply And.intro;
          · convert comp_asymptotic U ( m * p0 ) ( m • s ) ( Nat.mul_pos ( Nat.lt_trans Nat.zero_lt_one hm ) hp0 ) using 1;
            norm_num;
          · convert comp_asymptotic U p0 s hp0 using 1;
        convert h_comp_diff.1.sub h_comp_diff.2 using 2 ; ring;
    convert h_combined.1.add h_combined.2 using 2 ; unfold NML ; ring!
/-
Theorem 5(iv): NML selects p₀ over p for all sufficiently large T (i.e., NML(p) > NML(p0) eventually).
-/
theorem theorem_5_iv {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  ∀ᶠ T in Filter.atTop, NML U p s_p T hp > NML U p0 s T hp0 := by
    -- From theorem_5_iii, NML(p) - NML(p0) = C * log2(T) + O(1), where C = (m-1)*p0*|X|/2.
    have h_diff : ∃ C : ℝ, 0 < C ∧ Asymptotics.IsBigO Filter.atTop (fun T => NML U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0) - NML U p0 s T hp0 - C * Real.logb 2 T) (fun T => (1 : Real)) := by
      use (m - 1) * (p0 * Fintype.card X) / 2;
      refine' ⟨ div_pos ( mul_pos ( sub_pos.mpr ( Nat.one_lt_cast.mpr hm ) ) ( mul_pos ( Nat.cast_pos.mpr hp0 ) ( Nat.cast_pos.mpr ( Fintype.card_pos_iff.mpr ⟨ 0 ⟩ ) ) ) ) zero_lt_two, _ ⟩;
      convert theorem_5_iii U p0 s T0 hp0 h_eventual m hm using 1;
    obtain ⟨ C, hC₀, hC ⟩ := h_diff;
    -- Since $C > 0$, we have $C * \log_2(T) \to \infty$ as $T \to \infty$.
    have h_log_inf : Filter.Tendsto (fun T : ℕ => C * Real.logb 2 T) Filter.atTop Filter.atTop := by
      exact Filter.Tendsto.const_mul_atTop hC₀ ( Real.tendsto_logb_atTop ( by norm_num ) |> Filter.Tendsto.comp <| tendsto_natCast_atTop_atTop );
    rw [ Asymptotics.isBigO_iff ] at hC;
    obtain ⟨ c, hc ⟩ := hC;
    filter_upwards [ hc, h_log_inf.eventually_gt_atTop ( c + 1 ) ] with T hT₁ hT₂ using by norm_num at *; linarith [ abs_le.mp hT₁ ] ;
/-
Theorem 5(i): The per-site NLL rates are equal to 0 (formalized as NLL being o(T)).
-/
theorem theorem_5_i_proved {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) (fun T : ℕ => (T : Real)) ∧
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U p0 s T hp0) (fun T : ℕ => (T : Real)) := by
    convert theorem_5_i U p0 s T0 hp0 h_eventual m hm using 1
/-
Theorem 5(i): The per-site NLL rates are equal to 0.
-/
theorem theorem_5_i_proof {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U (m * p0) (m • s) T (Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0)) (fun T : ℕ => (T : Real)) ∧
  Asymptotics.IsLittleO Filter.atTop (fun T => NLL U p0 s T hp0) (fun T : ℕ => (T : Real)) := by
    convert theorem_5_i_proved U p0 s T0 hp0 h_eventual m hm using 1
/-
Theorem 5(ii): The NLL difference satisfies NLL(p, T) - NLL(p₀, T) = O(1).
-/
theorem theorem_5_ii_proof {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  Asymptotics.IsBigO Filter.atTop (fun T => NLL U p s_p T hp - NLL U p0 s T hp0) (fun T => (1 : Real)) := by
    -- Apply the lemma that states the NLL difference is O(1).
    apply theorem_5_ii U p0 s T0 hp0 h_eventual m hm
/-
Theorem 5(iii): The NML score difference satisfies NML(p, T) - NML(p₀, T) = (m-1)·k_{p₀}/2 · log₂ T + O(1).
-/
theorem theorem_5_iii_proof {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  let k_p0 := (p0 * Fintype.card X : ℝ)
  Asymptotics.IsBigO Filter.atTop (fun T => NML U p s_p T hp - NML U p0 s T hp0 - (m - 1 : ℝ) * k_p0 / 2 * Real.logb 2 T) (fun T => (1 : Real)) := by
    convert theorem_5_iii U p0 s T0 hp0 h_eventual m hm using 1
/-
Theorem 5(iv): NML selects p₀ over p for all sufficiently large T.
-/
theorem theorem_5_iv_proof {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p0 : ℕ) (s : X) (T0 : ℕ)
  (hp0 : p0 > 0)
  (h_eventual : EventuallyPeriodic U p0 s T0)
  (m : ℕ) (hm : m > 1) :
  let p := m * p0
  let s_p := m • s
  have hp : p > 0 := Nat.mul_pos (Nat.lt_trans Nat.zero_lt_one hm) hp0
  ∀ᶠ T in Filter.atTop, NML U p s_p T hp > NML U p0 s T hp0 := by
    convert theorem_5_iv U p0 s T0 hp0 h_eventual m hm using 1
