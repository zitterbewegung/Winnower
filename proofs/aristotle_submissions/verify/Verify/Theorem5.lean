            obtain ⟨ c, a, h ⟩ := h_log_term; use ⌈2 * c * p⌉₊ + a + 1; intro b hb; have := h b ( by linarith ) ; rw [ abs_le ] at this; nlinarith [ Nat.le_ceil ( 2 * c * p ), show ( b : ℝ ) ≥ ⌈2 * c * p⌉₊ + a + 1 by exact_mod_cast hb, show ( p : ℝ ) > 0 by positivity, mul_div_cancel₀ ( b : ℝ ) ( by positivity : ( p : ℝ ) ≠ 0 ) ] ;
          have h_log_term : ∀ᶠ T in Filter.atTop, Real.logb 2 ((count_in_class U p s T idx hp).1 : ℝ) ≤ Real.logb 2 (T / p : ℝ) + Real.logb 2 2 := by
            have h_log_term : ∀ᶠ T in Filter.atTop, (count_in_class U p s T idx hp).1 ≤ (T / p : ℝ) * 2 := by
