        exact tendsto_nhdsWithin_of_tendsto_nhds ( by simpa using Real.continuous_mul_log.neg.tendsto 0 );
      rw [ Asymptotics.isLittleO_iff_tendsto' ] <;> norm_num;
      · have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => Real.log (T + 1) / T) Filter.atTop (nhds 0) := by
          have h_log_div_T_zero : Filter.Tendsto (fun T : ℝ => (Real.log T + Real.log (1 + 1 / T)) / T) Filter.atTop (nhds 0) := by
            simpa [ add_div ] using h_log_div_T_zero.add ( Filter.Tendsto.div_atTop ( Filter.Tendsto.log ( tendsto_const_nhds.add ( tendsto_inv_atTop_zero ) ) ( by norm_num ) ) Filter.tendsto_id );
          refine h_log_div_T_zero.congr' ( by filter_upwards [ Filter.eventually_gt_atTop 0 ] with T hT using by rw [ one_add_div hT.ne', Real.log_div ] <;> ring <;> positivity );
