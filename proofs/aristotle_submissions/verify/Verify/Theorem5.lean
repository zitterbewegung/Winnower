/-
Lemma: If U is eventually periodic with (p, s), it is also eventually periodic with (m*p, m*s).
-/
lemma eventually_periodic_multiple {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
  (U : Spacetime X) (p : ℕ) (s : X) (T0 : ℕ)
  (h : EventuallyPeriodic U p s T0) (m : ℕ) (hm : m > 0) :
  EventuallyPeriodic U (m * p) (m • s) T0 := by
    intro t ht x; induction' m with m ih <;> simp_all +decide [ Nat.succ_mul, add_smul ] ; ring;
    by_cases hm : 0 < m <;> simp_all +decide [ ← add_assoc ];
    · rw [ ← ih, h ( t + m * p ) ( by nlinarith ) ( x + m • s ) ];
    · exact h t ht x
/-
