/-
Definitions of Spacetime and binary entropy h_b.
-/
def Spacetime (X : Type*) := ℕ → X → Bool
noncomputable def h_b (theta : Real) : Real :=
  if theta = 0 ∨ theta = 1 then 0 else - theta * Real.logb 2 theta - (1 - theta) * Real.logb 2 (1 - theta)
/-
Definitions of orbitIndex, count_in_class, NLL, and NML.
-/
variable {X : Type*} [AddCommGroup X] [Fintype X] [DecidableEq X]
/-- The orbit index maps a spacetime point (t, x) to its canonical representative in the fundamental domain. -/
def orbitIndex (p : ℕ) (s : X) (t : ℕ) (x : X) (hp : p > 0) : (Fin p) × X :=
  (⟨t % p, Nat.mod_lt _ hp⟩, x - (t / p) • s)
/-- Count total points and ones in a specific orbit class within the window [0, T). -/
def count_in_class (U : Spacetime X) (p : ℕ) (s : X) (T : ℕ) (idx : (Fin p) × X) (hp : p > 0) : ℕ × ℕ :=
  let total := (Finset.range T).sum (fun t => Finset.univ.filter (fun x => orbitIndex p s t x hp = idx) |>.card)
  let ones := (Finset.range T).sum (fun t => Finset.univ.filter (fun x => orbitIndex p s t x hp = idx ∧ U t x = true) |>.card)
  (total, ones)
/-- Negative Log Likelihood. -/
noncomputable def NLL (U : Spacetime X) (p : ℕ) (s : X) (T : ℕ) (hp : p > 0) : Real :=
  Finset.univ.sum (fun (idx : (Fin p) × X) =>
    let (n, k) := count_in_class U p s T idx hp
    if n = 0 then 0 else
    let theta := (k : Real) / n
    n * h_b theta
  )
/-- Normalized Maximum Likelihood score. -/
noncomputable def NML (U : Spacetime X) (p : ℕ) (s : X) (T : ℕ) (hp : p > 0) : Real :=
  NLL U p s T hp + Finset.univ.sum (fun (idx : (Fin p) × X) =>
    let (n, _) := count_in_class U p s T idx hp
    if n = 0 then 0 else 0.5 * Real.logb 2 n
  )
