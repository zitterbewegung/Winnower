/-
Formalization of Corollary D.3 from the paper, proving the unconditional convergence of the per-site NLL for a deterministic Cellular Automaton on a finite spatial domain. The proof leverages the eventual periodicity of the CA trajectory to show that orbit class frequencies and thus the NLL stabilize over time.
-/

import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

set_option maxHeartbeats 0
set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

/-
The trajectory of a CA given a rule and an initial configuration.
-/
def CA_trajectory {S : Type} (rule : (S → Bool) → (S → Bool)) (init : S → Bool) : ℕ → S → Bool
| 0 => init
| n + 1 => rule (CA_trajectory rule init n)

/-
A candidate model is defined by a temporal period `p` and a partition of `Fin p × S` into `k` orbit classes.
-/
structure CandidateModel (S : Type) [Fintype S] where
  p : ℕ
  hp : p > 0
  k : ℕ
  class_id : Fin p × S → Fin k

/-
Extend the class_id to all time steps using periodicity.
-/
def orbit_class {S : Type} [Fintype S] (model : CandidateModel S) (t : ℕ) (x : S) : Fin model.k :=
  model.class_id ⟨⟨t % model.p, Nat.mod_lt _ model.hp⟩, x⟩

/-
Count of sites in orbit class j up to time T.
-/
noncomputable def count_class {S : Type} [Fintype S] (model : CandidateModel S) (T : ℕ) (j : Fin model.k) : ℝ :=
  (Finset.filter (fun (tx : Fin T × S) => orbit_class model tx.1 tx.2 = j) Finset.univ).card

/-
Count of 1s in orbit class j up to time T for a given trajectory.
-/
noncomputable def count_ones {S : Type} [Fintype S] (model : CandidateModel S) (traj : ℕ → S → Bool) (T : ℕ) (j : Fin model.k) : ℝ :=
  (Finset.filter (fun (tx : Fin T × S) => orbit_class model tx.1 tx.2 = j ∧ traj tx.1 tx.2 = true) Finset.univ).card

/-
Empirical frequency of 1s in orbit class j.
-/
noncomputable def theta_hat {S : Type} [Fintype S] (model : CandidateModel S) (traj : ℕ → S → Bool) (T : ℕ) (j : Fin model.k) : ℝ :=
  if count_class model T j = 0 then 0 else count_ones model traj T j / count_class model T j

/-
Check if Real.binEntropy is available.
-/
#check Real.binEntropy

/-
The NLL per site is the sum of the entropy of each orbit class weighted by its size, divided by the total number of sites.
-/
noncomputable def NLL_per_site {S : Type} [Fintype S] (model : CandidateModel S) (traj : ℕ → S → Bool) (T : ℕ) : ℝ :=
  (∑ j : Fin model.k, count_class model T j * Real.binEntropy (theta_hat model traj T j)) / (T * Fintype.card S)

/-
The trajectory of a deterministic CA on a finite domain is eventually periodic.
-/
def EventuallyPeriodic {α : Type} (f : ℕ → α) : Prop :=
  ∃ T p, p > 0 ∧ ∀ t ≥ T, f (t + p) = f t

lemma CA_eventually_periodic {S : Type} [Fintype S] (rule : (S → Bool) → (S → Bool)) (init : S → Bool) :
  EventuallyPeriodic (CA_trajectory rule init) := by
  -- By definition of periodicity, there exists some $N$ such that for all $n \geq N$, $CA\_trajectory rule init (n + p) = CA\_trajectory rule init n$.
  obtain ⟨n, m, hnm, h_eq⟩ : ∃ n m, n < m ∧ CA_trajectory rule init n = CA_trajectory rule init m := by
    by_contra h;
    exact absurd ( Set.infinite_range_of_injective ( fun n m hnm => le_antisymm ( not_lt.1 fun hnm' => h ⟨ m, n, hnm', hnm.symm ⟩ ) ( not_lt.1 fun hnm' => h ⟨ n, m, hnm', hnm ⟩ ) ) ) ( Set.not_infinite.mpr <| Set.toFinite _ );
  use n, m - n, Nat.sub_pos_of_lt hnm, ?_;
  intro t ht; induction ht <;> simp_all +decide [ ← add_assoc, Nat.succ_add, le_of_lt ] ;
  rw [ Nat.add_succ, Nat.add_succ, CA_trajectory ] ; aesop;

