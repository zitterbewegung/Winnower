/-
Count of sites in orbit class j at time t.
-/
noncomputable def count_class_at_t {S : Type} [Fintype S] (model : CandidateModel S) (j : Fin model.k) (t : ℕ) : ℝ :=
  (Finset.filter (fun x => orbit_class model t x = j) Finset.univ).card

/-
Count of 1s in orbit class j at time t.
-/
noncomputable def count_ones_at_t {S : Type} [Fintype S] (model : CandidateModel S) (traj : ℕ → S → Bool) (j : Fin model.k) (t : ℕ) : ℝ :=
  (Finset.filter (fun x => orbit_class model t x = j ∧ traj t x = true) Finset.univ).card

/-
The count of sites in an orbit class is periodic.
-/
lemma count_class_periodic {S : Type} [Fintype S] (model : CandidateModel S) (j : Fin model.k) :
  EventuallyPeriodic (count_class_at_t model j) := by
  use 0, model.p, model.hp, by
    unfold count_class_at_t orbit_class; aesop;;

/-
The count of 1s in an orbit class is eventually periodic.
-/
lemma count_ones_eventually_periodic {S : Type} [Fintype S] (model : CandidateModel S) (rule : (S → Bool) → (S → Bool)) (init : S → Bool) (j : Fin model.k) :
  EventuallyPeriodic (count_ones_at_t model (CA_trajectory rule init) j) := by
  obtain ⟨ T, p, hp, h ⟩ := CA_eventually_periodic rule init;
  use T, p * model.p;
  -- By definition of `count_ones_at_t`, we need to show that the number of 1s in orbit class j at time `t + p * model.p` is the same as at time `t`.
  have h_count_eq : ∀ t ≥ T, ∀ x : S, (CA_trajectory rule init (t + p * model.p) x = true) ↔ (CA_trajectory rule init t x = true) := by
    intro t ht x; rw [ show t + p * model.p = t + p * model.p from rfl, show CA_trajectory rule init ( t + p * model.p ) = CA_trajectory rule init t from Nat.recOn model.p ( by norm_num ) fun n ihn => by rw [ Nat.mul_succ, ← add_assoc, h _ ( by nlinarith ), ihn ] ] ;
  refine' ⟨ Nat.mul_pos hp model.hp, fun t ht => _ ⟩;
  unfold count_ones_at_t;
  unfold orbit_class; simp +decide [ *, Nat.add_mod, Nat.mod_eq_of_lt model.hp ] ;

/-
The cumulative count of sites in an orbit class is the sum of the per-time-step counts.
-/
lemma count_class_eq_sum {S : Type} [Fintype S] (model : CandidateModel S) (T : ℕ) (j : Fin model.k) :
  count_class model T j = ∑ t ∈ Finset.range T, count_class_at_t model j t := by
  unfold count_class count_class_at_t;
  simp +decide only [Finset.card_filter];
  erw [ Finset.sum_product ] ; norm_num [ Finset.sum_range ]

/-
The cumulative count of 1s in an orbit class is the sum of the per-time-step counts.
-/
lemma count_ones_eq_sum {S : Type} [Fintype S] (model : CandidateModel S) (traj : ℕ → S → Bool) (T : ℕ) (j : Fin model.k) :
  count_ones model traj T j = ∑ t ∈ Finset.range T, count_ones_at_t model traj j t := by
  unfold count_ones count_ones_at_t;
  simp +decide only [Finset.card_filter];
  erw [ Finset.sum_product ] ; norm_cast ; simp +decide [ Finset.sum_range ] ;

/-
The average count of sites in an orbit class converges.
-/
lemma count_class_converges {S : Type} [Fintype S] (model : CandidateModel S) (j : Fin model.k) :
  ∃ L, Filter.Tendsto (fun T => count_class model T j / T) Filter.atTop (nhds L) := by
  convert avg_converges_of_eventually_periodic ( fun T => count_class_at_t model j T ) ( count_class_periodic model j ) using 1;
  simp +decide only [count_class_eq_sum]

/-
The average count of 1s in an orbit class converges.
-/
lemma count_ones_converges {S : Type} [Fintype S] (model : CandidateModel S) (rule : (S → Bool) → (S → Bool)) (init : S → Bool) (j : Fin model.k) :
  ∃ L, Filter.Tendsto (fun T => count_ones model (CA_trajectory rule init) T j / T) Filter.atTop (nhds L) := by
  convert avg_converges_of_eventually_periodic ( fun T => count_ones_at_t model ( CA_trajectory rule init ) j T ) _;
  · exact?;
  · exact?

/-
The NLL term for a single orbit class converges.
-/
lemma term_converges {S : Type} [Fintype S] (model : CandidateModel S) (rule : (S → Bool) → (S → Bool)) (init : S → Bool) (j : Fin model.k) :
  ∃ L, Filter.Tendsto (fun T => (count_class model T j / T) * Real.binEntropy (theta_hat model (CA_trajectory rule init) T j)) Filter.atTop (nhds L) := by
  -- By definition of $c_T$ and $o_T$, we know that $c_T \to c$ and $o_T \to o$ for some $c, o$.
  obtain ⟨c, hc⟩ : ∃ c, Filter.Tendsto (fun T => count_class model T j / T) Filter.atTop (nhds c) := by
    exact count_class_converges model j
  obtain ⟨o, ho⟩ : ∃ o, Filter.Tendsto (fun T => count_ones model (CA_trajectory rule init) T j / T) Filter.atTop (nhds o) := by
    exact?;
  by_cases hc0 : c = 0;
  · -- Since $c = 0$, we have $\theta_hat \to 0$ as well.
    have h_theta_hat_zero : ∀ T, theta_hat model (CA_trajectory rule init) T j ∈ Set.Icc 0 1 := by
      intro T
      unfold theta_hat
      simp [count_class, count_ones];
      split_ifs <;> norm_num;
      exact ⟨ div_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ), div_le_one_of_le₀ ( mod_cast Finset.card_mono <| fun x hx => by aesop ) ( Nat.cast_nonneg _ ) ⟩;
    -- Since $c = 0$, we have $\binEntropy(\theta_hat) \leq \binEntropy(1/2) = \log 2$.
    have h_binEntropy_bound : ∀ T, Real.binEntropy (theta_hat model (CA_trajectory rule init) T j) ≤ Real.log 2 := by
      exact?;
    exact ⟨ _, squeeze_zero ( fun T => mul_nonneg ( div_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( Real.binEntropy_nonneg ( h_theta_hat_zero T |>.1 ) ( h_theta_hat_zero T |>.2 ) ) ) ( fun T => mul_le_mul_of_nonneg_left ( h_binEntropy_bound T ) ( div_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ) ( by simpa [ hc0 ] using hc.mul_const ( Real.log 2 ) ) ⟩;
  · have h_theta_hat : Filter.Tendsto (fun T => theta_hat model (CA_trajectory rule init) T j) Filter.atTop (nhds (o / c)) := by
      refine' Filter.Tendsto.congr' _ ( ho.div hc hc0 );
      filter_upwards [ hc.eventually_ne hc0 ] with T hT ; unfold theta_hat ; by_cases hT' : ( Finset.filter ( fun x : Fin T × S => orbit_class model x.1 x.2 = j ) Finset.univ ).card = 0 <;> simp_all +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm ] ;
    have h_binEntropy_cont : ContinuousAt Real.binEntropy (o / c) := by
      fun_prop;
    exact ⟨ _, Filter.Tendsto.mul hc ( h_binEntropy_cont.tendsto.comp h_theta_hat ) ⟩

/-
For a deterministic CA on a finite spatial domain, the per-site NLL converges unconditionally.
-/
theorem corollary_d3 {S : Type} [Fintype S] (rule : (S → Bool) → (S → Bool)) (init : S → Bool) (model : CandidateModel S) :
  ∃ limit_val : ℝ, Filter.Tendsto (fun T => NLL_per_site model (CA_trajectory rule init) T) Filter.atTop (nhds limit_val) := by
  -- By lemma `term_converges`, for each orbit class `j`, the term `(count_class model T j / T) * Real.binEntropy (theta_hat model (CA_trajectory rule init) T j)` converges.
  have h_term_converge : ∀ j, ∃ L, Filter.Tendsto (fun T => (count_class model T j / T) * Real.binEntropy (theta_hat model (CA_trajectory rule init) T j)) Filter.atTop (nhds L) := by
    exact?;
  choose L hL using h_term_converge;
  -- The NLL per site is `(1 / |S|) * ∑ j, (count_class model T j / T) * Real.binEntropy (theta_hat model traj T j)`.
  use (∑ j : Fin model.k, L j) / (Fintype.card S : ℝ);
  convert Filter.Tendsto.div_const ( tendsto_finset_sum _ fun j _ => hL j ) ( Fintype.card S : ℝ ) using 2 ; unfold NLL_per_site ; ring;
  simp +decide only [mul_comm, Finset.mul_sum _ _ _, mul_left_comm, mul_assoc]

