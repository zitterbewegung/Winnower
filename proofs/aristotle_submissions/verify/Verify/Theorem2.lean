open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- Condition (i): p₂ = m·p₁ and s₂ ≡ m·s₁ (mod D). -/
def cond1 (c₁ c₂ : Candidate n) : Prop :=
  ∃ m : ℕ, m ≥ 1 ∧ c₂.p = m * c₁.p ∧ ∀ i, (c₂.s i : ZMod (D i)) = m * (c₁.s i : ZMod (D i))

/-- Condition (ii): τ₂ = τ₁ᵐ. -/
def cond2 (c₁ c₂ : Candidate n) : Prop :=
  ∃ m : ℕ, m ≥ 1 ∧ gridTranslate n D T c₂ = (gridTranslate n D T c₁)^[m]

/-- Condition (iii): Π₂ refines Π₁. -/
def cond3 (c₁ c₂ : Candidate n) : Prop :=
  ∀ o₂ ∈ orbitPartition n D T c₂, ∃ o₁ ∈ orbitPartition n D T c₁, o₂ ⊆ o₁

/-- Condition (iv): B₁ ⊆ B₂. -/
def cond4 (c₁ c₂ : Candidate n) : Prop :=
  ModelClass n D T c₁ ⊆ ModelClass n D T c₂

/-- Condition (v): d*_U(c₂) ≤ d*_U(c₁) for all U. -/
def cond5 (c₁ c₂ : Candidate n) : Prop :=
  ∀ U, minHammingDist n D T c₂ U ≤ minHammingDist n D T c₁ U

/-- Condition (vi): NLL_U(c₂) ≤ NLL_U(c₁) for all U. -/
def cond6 (c₁ c₂ : Candidate n) : Prop :=
  ∀ U, NLL n D T c₂ U ≤ NLL n D T c₁ U

