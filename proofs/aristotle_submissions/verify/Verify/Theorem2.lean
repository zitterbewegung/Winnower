    have h_eq : o₃ = o₁ := by
      have := h_partition₁.2;
      exact ExistsUnique.unique ( this x ) ⟨ ho₃.1, ho₃.2 ho₂.2 ⟩ ⟨ ho₁, hx ⟩
    aesop⟩;

/-
Prove that condition (iii) implies condition (vi) using the helper lemmas.
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

theorem cond3_imp_cond6 (c₁ c₂ : Candidate n) : cond3 n D T c₁ c₂ → cond6 n D T c₁ c₂ := by
  intro h;
  intro U;
  -- Group the sum in NLL(c₂) by the orbits in Π₁.
  have h_group : ∑ o₂ ∈ (orbitPartition n D T c₂).toFinset, (o₂.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o₂) = ∑ o₁ ∈ (orbitPartition n D T c₁).toFinset, ∑ o₂ ∈ (orbitPartition n D T c₂).toFinset.filter (fun o => o ⊆ o₁), (o₂.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o₂) := by
    convert sum_partition_refinement n D T ( orbitPartition n D T c₁ |> Set.toFinset ) ( orbitPartition n D T c₂ |> Set.toFinset ) _ _ _ _ using 1;
    · have := orbitPartition_isPartition n D T c₁; aesop;
    · convert orbitPartition_isPartition n D T c₂ using 1;
      simp +zetaDelta at *;
    · aesop;
  -- For each o₁, the inner sum is bounded by |o₁| * H(p(o₁)) using Jensen's inequality (entropy_inequality_for_partition).
  have h_jensen : ∀ o₁ ∈ (orbitPartition n D T c₁).toFinset, ∑ o₂ ∈ (orbitPartition n D T c₂).toFinset.filter (fun o => o ⊆ o₁), (o₂.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o₂) ≤ (o₁.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o₁) := by
    intros o₁ ho₁
    have h_union : ⋃ o₂ ∈ (orbitPartition n D T c₂).toFinset.filter (fun o => o ⊆ o₁), o₂ = o₁ := by
      apply partition_refinement_union;
      any_goals exact ( orbitPartition n D T c₁ ).toFinset;
      · convert orbitPartition_isPartition n D T c₁ using 1;
        ext; simp [orbitPartition];
      · convert orbitPartition_isPartition n D T c₂ using 1;
        ext; simp [orbitPartition];
      · aesop;
      · exact ho₁;
    convert entropy_inequality_for_partition n D T o₁ _ U _ _ using 1;
    · intros o₁_1 ho₁_1 o₂ ho₂ hne; exact (by
      have h_partition : Setoid.IsPartition (orbitPartition n D T c₂) := by
        exact orbitPartition_isPartition n D T c₂;
      have := h_partition.2;
      exact Set.disjoint_left.mpr fun x hx₁ hx₂ => hne <| ExistsUnique.unique ( this x ) ⟨ by aesop, hx₁ ⟩ ⟨ by aesop, hx₂ ⟩);
    · exact h_union;
  exact h_group.le.trans ( Finset.sum_le_sum h_jensen )

