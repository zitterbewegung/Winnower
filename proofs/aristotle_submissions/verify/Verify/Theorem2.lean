open BigOperators

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- The minimum Hamming distance from U to any field in the model class of c. -/
noncomputable def minHammingDist (c : Candidate n) (U : BinaryField n D T) : ℕ :=
  sInf { d | ∃ V ∈ ModelClass n D T c, d = hammingDist U V }

