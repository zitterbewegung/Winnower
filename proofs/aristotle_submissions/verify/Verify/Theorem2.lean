/-
Prove that condition (vi) implies condition (iii).
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

theorem cond6_imp_cond3 (c₁ c₂ : Candidate n) : cond6 n D T c₁ c₂ → cond3 n D T c₁ c₂ := by
  intro h
  by_contra h_not_r
  obtain ⟨o₂, ho₂⟩ : ∃ o₂ ∈ orbitPartition n D T c₂, ¬∃ o₁ ∈ orbitPartition n D T c₁, o₂ ⊆ o₁ := by
    contrapose! h_not_r; aesop;
  obtain ⟨x, hx_o₂, y, hy_o₂, hxy⟩ : ∃ x ∈ o₂, ∃ y ∈ o₂, ∃ o₁_x ∈ orbitPartition n D T c₁, x ∈ o₁_x ∧ y∉ o₁_x := by
    obtain ⟨x, hx_o₂⟩ : ∃ x ∈ o₂, ∃ o₁_x ∈ orbitPartition n D T c₁, x ∈ o₁_x := by
      obtain ⟨ x, hx ⟩ := ho₂.1;
      exact ⟨ x, hx.symm ▸ Set.mem_setOf.mpr ⟨ 0, rfl ⟩, _, ⟨ x, rfl ⟩, Set.mem_setOf.mpr ⟨ 0, rfl ⟩ ⟩;
    grind
  set U : BinaryField n D T := fun z => if ∃ o₁ ∈ orbitPartition n D T c₁, z ∈ o₁ ∧ o₁ = {z' | ∃ k : ℕ, z' = (gridTranslate n D T c₁)^[k] x} then true else false with hU_def
  have hNLL_c1 : NLL n D T c₁ U = 0 := by
    refine' Finset.sum_eq_zero fun o ho => _;
    -- Since $U$ is constant on each orbit of $c₁$, the empirical probability on $o$ is either 0 or 1.
    have h_empirical_prob : empiricalProb n D T U o = 0 ∨ empiricalProb n D T U o = 1 := by
      by_cases h : ∃ o₁ ∈ orbitPartition n D T c₁, o = o₁ ∧ o₁ = {z' | ∃ k : ℕ, z' = (gridTranslate n D T c₁)^[k] x} <;> simp_all +decide [ empiricalProb ];
      · by_cases h : Set.ncard { z' | ∃ k : ℕ, z' = ( gridTranslate n D T c₁ )^[k] x } = 0 <;> aesop;
      · by_cases h' : { z' | ∃ k : ℕ, z' = ( gridTranslate n D T c₁ ) ^[ k ] x } ∈ orbitPartition n D T c₁ <;> simp_all +decide [ Set.ncard_eq_toFinset_card' ];
        -- Since $o$ is in the orbit partition of $c₁$, and the set $\{z' | \exists k, z' = (gridTranslate n D T c₁)^[k] x\}$ is also in the orbit partition of $c₁$, they must be either the same or disjoint.
        have h_disjoint : o = {z' | ∃ k : ℕ, z' = (gridTranslate n D T c₁)^[k] x} ∨ Disjoint o {z' | ∃ k : ℕ, z' = (gridTranslate n D T c₁)^[k] x} := by
          have h_disjoint : ∀ o₁ o₂ : Set (SpacetimeGrid n D T), o₁ ∈ orbitPartition n D T c₁ → o₂ ∈ orbitPartition n D T c₁ → o₁ ≠ o₂ → Disjoint o₁ o₂ := by
            intros o₁ o₂ ho₁ ho₂ hne; exact (by
            have := orbitPartition_isPartition n D T c₁; simp_all +decide [ Setoid.IsPartition ] ;
            exact Set.disjoint_left.mpr fun x hx₁ hx₂ => hne <| ExistsUnique.unique ( this.2 _ _ ) ⟨ ho₁, hx₁ ⟩ ⟨ ho₂, hx₂ ⟩);
          exact Or.inr <| h_disjoint _ _ ho h' h;
        simp_all +decide [ Finset.ext_iff, Set.disjoint_left ];
    aesop
  have hNLL_c2 : NLL n D T c₂ U > 0 := by
    have hNLL_c2_pos : Real.binEntropy (empiricalProb n D T U o₂) > 0 := by
      have hNLL_c2_pos : 0 < empiricalProb n D T U o₂ ∧ empiricalProb n D T U o₂ < 1 := by
        constructor <;> norm_num [ empiricalProb ] at *;
        · refine' div_pos ( Nat.cast_pos.mpr _ ) ( Nat.cast_pos.mpr _ ) <;> norm_num [ Set.ncard_eq_toFinset_card' ] at *;
          · use x; simp [hx_o₂, hU_def];
            exact ⟨ ⟨ x, rfl ⟩, 0, rfl ⟩;
          · exact ⟨ x, Finset.mem_filter.mpr ⟨ Finset.mem_univ _, hx_o₂ ⟩ ⟩;
        · rw [ div_lt_one ] <;> norm_cast <;> norm_num [ Set.ncard_eq_toFinset_card' ] at *;
          · refine' Finset.card_lt_card _ ; simp_all +decide [ Finset.subset_iff ] ; (
            simp_all +decide [ Finset.ssubset_def, Finset.subset_iff ];
            grind);
          · exact ⟨ x, Finset.mem_filter.mpr ⟨ Finset.mem_univ _, hx_o₂ ⟩ ⟩;
      norm_num [ Real.binEntropy ] at *;
      nlinarith [ Real.log_le_sub_one_of_pos ( by linarith : 0 < 1 - empiricalProb n D T U o₂ ), Real.log_le_sub_one_of_pos ( by linarith : 0 < empiricalProb n D T U o₂ ) ];
    refine' lt_of_lt_of_le _ ( Finset.single_le_sum ( fun o _ => _ ) ( show o₂ ∈ ( orbitPartition n D T c₂ ).toFinset from _ ) ) <;> norm_num [ hNLL_c2_pos ];
    · exact Nat.pos_of_ne_zero ( by intro h; simp_all +decide [ Set.ncard_eq_toFinset_card' ] );
    · refine' mul_nonneg ( Nat.cast_nonneg _ ) _;
      apply_rules [ Real.binEntropy_nonneg ];
      · exact div_nonneg ( Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ );
      · refine' div_le_one_of_le₀ _ _ <;> norm_num [ Set.ncard_eq_toFinset_card' ];
        exact Finset.card_le_card fun x hx => by aesop;
    · exact ho₂.1
  have h_contra : NLL n D T c₂ U ≤ NLL n D T c₁ U := by
    exact h U
  linarith

