open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

theorem cond5_imp_cond3 (c₁ c₂ : Candidate n) : cond5 n D T c₁ c₂ → cond3 n D T c₁ c₂ := by
  intro h
  by_contra h_not_refine
  obtain ⟨o₂, ho₂⟩ : ∃ o₂ ∈ orbitPartition n D T c₂, ∃ o₁₁ o₁₂, o₁₁ ∈ orbitPartition n D T c₁ ∧ o₁₂ ∈ orbitPartition n D T c₁ ∧ o₁₁ ≠ o₁₂ ∧ ∃ x₁ ∈ o₂, x₁ ∈ o₁₁ ∧ ∃ x₂ ∈ o₂, x₂ ∈ o₁₂ := by
    simp_all +decide [ cond3 ];
    obtain ⟨ o₂, ho₂₁, ho₂₂ ⟩ := h_not_refine;
    obtain ⟨x₁, hx₁⟩ : ∃ x₁ ∈ o₂, ∃ o₁₁ ∈ orbitPartition n D T c₁, x₁ ∈ o₁₁ := by
      obtain ⟨ x₁, hx₁ ⟩ := ho₂₁;
      exact ⟨ x₁, hx₁.symm ▸ Set.mem_setOf.mpr ⟨ 0, rfl ⟩, _, ⟨ x₁, rfl ⟩, Set.mem_setOf.mpr ⟨ 0, rfl ⟩ ⟩;
    obtain ⟨o₁₁, ho₁₁₁, ho₁₁₂⟩ := hx₁.right
    obtain ⟨x₂, hx₂⟩ : ∃ x₂ ∈ o₂, x₂ ∉ o₁₁ := by
      exact Set.not_subset.mp ( ho₂₂ o₁₁ ho₁₁₁ );
    obtain ⟨o₁₂, ho₁₂₁, ho₁₂₂⟩ : ∃ o₁₂ ∈ orbitPartition n D T c₁, x₂ ∈ o₁₂ := by
      exact ⟨ _, ⟨ x₂, rfl ⟩, by tauto ⟩;
    exact ⟨ o₂, ho₂₁, o₁₁, ho₁₁₁, o₁₂, ho₁₂₁, by aesop, x₁.1, x₁.2, hx₁.1, ho₁₁₂, x₂.1, x₂.2, hx₂.1, ho₁₂₂ ⟩;
  obtain ⟨ o₁₁, o₁₂, ho₁₁, ho₁₂, ho₁₁₂, x₁, hx₁₁, hx₁₂, x₂, hx₂₁, hx₂₂ ⟩ := ho₂.2
  obtain ⟨U, hU⟩ : ∃ U : BinaryField n D T, (∀ x ∈ o₁₁, U x = true) ∧ (∀ x ∈ o₁₂, U x = false) ∧ (∀ o ∈ orbitPartition n D T c₁, ∀ x y, x ∈ o → y ∈ o → U x = U y) := by
    use fun x => if ∃ o ∈ orbitPartition n D T c₁, x ∈ o ∧ o = o₁₁ then true else false;
    refine' ⟨ _, _, _ ⟩ <;> simp_all +decide [ Setoid.IsPartition ];
    · intro a b hab hba; have := orbitPartition_isPartition n D T c₁; have := this.2; simp_all +decide [ Setoid.IsPartition ] ;
      exact ho₁₁₂ <| ExistsUnique.unique ( this a b ) ⟨ ho₁₁, hba ⟩ ⟨ ho₁₂, hab ⟩;
    · intro o ho a b a' b' ha hb; have := orbitPartition_isPartition n D T c₁; simp_all +decide [ Setoid.IsPartition ] ;
      cases this.2 a b ; cases this.2 a' b' ; aesop;
  -- Then d*_U(c₁) = 0 (since U ∈ B₁).
  have h_d1 : minHammingDist n D T c₁ U = 0 := by
    exact le_antisymm ( csInf_le ⟨ 0, fun d hd => Nat.zero_le _ ⟩ ⟨ U, ⟨ fun o ho x y hx hy => hU.2.2 o ho x y hx hy, by aesop ⟩ ⟩ ) ( Nat.zero_le _ );
  -- However, o₂ contains x (where U=1) and some y (where U=0, since y∉o₁_x).
  have h_d2 : ∀ V ∈ ModelClass n D T c₂, hammingDist U V ≥ 1 := by
    intro V hV
    have h_const : ∀ x y, x ∈ o₂ → y ∈ o₂ → V x = V y := by
      exact fun x y hx hy => hV o₂ ho₂.1 x y hx hy;
    by_cases h : V x₁ = Bool.true <;> simp_all +decide [ hammingDist ];
    · exact ⟨ x₂, by specialize h_const _ _ _ _ hx₁₁ hx₂₁; aesop ⟩;
    · exact ⟨ x₁, by aesop ⟩;
  -- Thus d*_U(c₂) > 0.
  have h_d2_pos : minHammingDist n D T c₂ U > 0 := by
    exact lt_of_lt_of_le zero_lt_one <| le_csInf ⟨ _, ⟨ fun _ => Bool.true, by
      exact fun o ho x y hx hy => rfl, rfl ⟩ ⟩ fun d hd => hd.choose_spec.2.symm ▸ h_d2 _ hd.choose_spec.1;
  linarith [ h U ]

