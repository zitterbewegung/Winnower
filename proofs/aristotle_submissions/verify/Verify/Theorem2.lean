/-
Prove that condition (iii) implies condition (vi) (successful version).
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

theorem cond3_imp_cond6_success (c₁ c₂ : Candidate n) : cond3 n D T c₁ c₂ → cond6 n D T c₁ c₂ := by
  intro h3 U
  let s₁ := (orbitPartition n D T c₁).toFinset
  let s₂ := (orbitPartition n D T c₂).toFinset
  
  have h_part₁ : Setoid.IsPartition (s₁ : Set (Set (SpacetimeGrid n D T))) := by
    rw [Set.coe_toFinset]
    exact orbitPartition_isPartition n D T c₁
    
  have h_part₂ : Setoid.IsPartition (s₂ : Set (Set (SpacetimeGrid n D T))) := by
    rw [Set.coe_toFinset]
    exact orbitPartition_isPartition n D T c₂

  have h_refine : ∀ o₂ ∈ s₂, ∃ o₁ ∈ s₁, o₂ ⊆ o₁ := by
    intro o₂ ho₂
    rw [Set.mem_toFinset] at ho₂
    obtain ⟨o₁, ho₁, hsub⟩ := h3 o₂ ho₂
    use o₁
    rw [Set.mem_toFinset]
    exact ⟨ho₁, hsub⟩

  unfold NLL
  let f := fun o => (o.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o)
  change ∑ o₂ ∈ s₂, f o₂ ≤ ∑ o₁ ∈ s₁, f o₁
  
  calc ∑ o₂ ∈ s₂, f o₂
    _ = ∑ o₁ ∈ s₁, ∑ o₂ ∈ s₂.filter (fun o => o ⊆ o₁), f o₂ := by
      exact sum_partition_refinement n D T s₁ s₂ f h_part₁ h_part₂ h_refine
    _ ≤ ∑ o₁ ∈ s₁, f o₁ := by
      apply Finset.sum_le_sum
      intro o₁ ho₁
      let S := s₂.filter (fun o => o ⊆ o₁)
      have h_disjoint : ∀ a ∈ S, ∀ b ∈ S, a ≠ b → Disjoint a b := by
        intros a ha b hb hab
        rw [Finset.mem_filter] at ha hb
        apply Setoid.IsPartition.pairwiseDisjoint h_part₂ ha.1 hb.1 hab
      have h_union : ⋃ o ∈ S, o = o₁ := by
        apply partition_refinement_union n D T s₁ s₂ h_part₁ h_part₂ h_refine o₁ ho₁
      convert entropy_inequality_for_partition n D T o₁ S U h_disjoint h_union

/-
Define cond1_mod and prove gridTranslate_iterate.
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- Condition (i) interpreted with modular arithmetic for time. -/
def cond1_mod (c₁ c₂ : Candidate n) : Prop :=
  ∃ m : ℕ, m ≥ 1 ∧ (c₂.p : ZMod T) = m * (c₁.p : ZMod T) ∧ ∀ i, (c₂.s i : ZMod (D i)) = m * (c₁.s i : ZMod (D i))

lemma gridTranslate_iterate (c : Candidate n) (m : ℕ) (pt : SpacetimeGrid n D T) :
    (gridTranslate n D T c)^[m] pt = (pt.1 + m * (c.p : ZMod T), fun i => pt.2 i + m * (c.s i : ZMod (D i))) := by
      induction m <;> simp_all +decide [ Function.iterate_succ_apply', add_mul ];
      unfold gridTranslate; simp +decide [ add_assoc ] ;

