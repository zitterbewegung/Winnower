variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- The empirical probability of 1 in an orbit class for a field U. -/
noncomputable def empiricalProb (U : BinaryField n D T) (o : Set (SpacetimeGrid n D T)) : ℝ :=
  ({x ∈ o | U x = true}).ncard / o.ncard

/-- The Bernoulli negative log-likelihood of a candidate c given a field U. -/
noncomputable def NLL (c : Candidate n) (U : BinaryField n D T) : ℝ :=
  ∑ o ∈ (orbitPartition n D T c).toFinset, (o.ncard : ℝ) * Real.binEntropy (empiricalProb n D T U o)

