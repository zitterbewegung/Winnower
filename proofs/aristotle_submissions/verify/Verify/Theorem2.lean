/-
Prove that condition (iii) implies condition (ii).
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

theorem cond3_imp_cond2 (c₁ c₂ : Candidate n) : cond3 n D T c₁ c₂ → cond2 n D T c₁ c₂ := by
  intro h3
  obtain ⟨m, hm⟩ : ∃ m : ℕ, m ≥ 1 ∧ (gridTranslate n D T c₂) (0, 0) = (gridTranslate n D T c₁)^[m] (0, 0) := by
    -- By definition of $cond3$, we know that $orbit(c₂, 0) \subseteq orbit(c₁, 0)$.
    have h_orbit_subset : (gridTranslate n D T c₂) (0, 0) ∈ gridOrbit n D T c₁ (0, 0) := by
      have h_orbit_subset : gridOrbit n D T c₂ (0, 0) ⊆ gridOrbit n D T c₁ (0, 0) := by
        intro x hx
        obtain ⟨o₁, ho₁⟩ := h3 (gridOrbit n D T c₂ (0, 0)) (by
        exact ⟨ _, rfl ⟩)
        generalize_proofs at *; (
        -- Since $o₁$ is in the orbit partition of $c₁$, it must be the orbit of some point under $c₁$. But since $o₁$ contains $(0,0)$, that point must be $(0,0)$ itself.
        obtain ⟨pt, hpt⟩ : ∃ pt, o₁ = gridOrbit n D T c₁ pt := by
          exact Exists.imp ( by tauto ) ( Set.mem_setOf.mp ho₁.1 )
        generalize_proofs at *; (
        have h_pt_zero : pt ∈ gridOrbit n D T c₁ (0, 0) := by
          have h_pt_zero : (0, 0) ∈ gridOrbit n D T c₁ pt := by
            exact hpt ▸ ho₁.2 ( Set.mem_setOf.mpr ⟨ 0, rfl ⟩ ) |> fun h => by simpa using h;
          generalize_proofs at *; (
          obtain ⟨ k, hk ⟩ := h_pt_zero
          generalize_proofs at *; (
          use k * (T * ∏ i, D i) - k
          generalize_proofs at *; (
          rw [ hk, ← Function.iterate_add_apply ] ; ring; (
          -- Since $T$ and $\prod_{i} D_i$ are both positive, we can simplify the expression.
          have h_simplify : (gridTranslate n D T c₁)^[T * ∏ i, D i] pt = pt := by
            have h_simplify : ∀ m : ℕ, (gridTranslate n D T c₁)^[m] pt = (pt.1 + m * (c₁.p : ZMod T), fun i => pt.2 i + m * (c₁.s i : ZMod (D i))) := by
              exact fun m => gridTranslate_iterate n D T c₁ m pt
            generalize_proofs at *; (
            simp +decide [ h_simplify, Finset.prod_eq_zero_iff, NeZero.ne ];
            exact Prod.ext rfl ( funext fun i => by simp +decide [ Finset.prod_eq_prod_diff_singleton_mul ( Finset.mem_univ i ) ] ) ;)
          generalize_proofs at *; (
          rw [ show k + ( k * T * ∏ i, D i - k ) = k * T * ∏ i, D i by rw [ add_tsub_cancel_of_le ( by nlinarith [ show 0 < T * ∏ i, D i from mul_pos ( NeZero.pos T ) ( Finset.prod_pos fun i _ => NeZero.pos ( D i ) ) ] ) ] ] ; simp +decide [ *, mul_assoc, Function.iterate_mul, Function.iterate_fixed ] ;
          simp +decide [ ← Function.iterate_mul, mul_assoc, h_simplify ];
          rw [ Nat.mul_comm, Function.iterate_mul, Function.iterate_fixed h_simplify ])))))
        generalize_proofs at *; (
        have h_pt_zero : gridOrbit n D T c₁ pt ⊆ gridOrbit n D T c₁ (0, 0) := by
          obtain ⟨ k, hk ⟩ := h_pt_zero
          generalize_proofs at *; (
          intro x hx; obtain ⟨ m, hm ⟩ := hx; use m + k; simp +decide [ hm, Function.iterate_add_apply, hk ] ;)
        generalize_proofs at *; (
        exact h_pt_zero <| hpt ▸ ho₁.2 hx))))
      generalize_proofs at *; (
      exact h_orbit_subset ⟨ 1, rfl ⟩)
    generalize_proofs at *; (
    obtain ⟨ m, hm ⟩ := h_orbit_subset;
    by_cases hm1 : m = 0
    generalize_proofs at *; (
    use T * (∏ i, D i);
    refine' ⟨ Nat.mul_pos ( NeZero.pos T ) ( Finset.prod_pos fun _ _ => NeZero.pos _ ), _ ⟩
    generalize_proofs at *; (
    -- By definition of $gridTranslate$, we have:
    have h_gridTranslate_iterate : ∀ k : ℕ, (gridTranslate n D T c₁)^[k] (0, 0) = (k * (c₁.p : ZMod T), fun i => k * (c₁.s i : ZMod (D i))) := by
      intro k; simpa using gridTranslate_iterate n D T c₁ k (0, 0)
    generalize_proofs at *; (
    simp_all +decide [ ZMod.natCast_eq_zero_iff ];
    ext i; simp +decide [ Finset.prod_eq_prod_diff_singleton_mul ( Finset.mem_univ i ) ] ;)));
    exact ⟨ m, Nat.pos_of_ne_zero hm1, hm ⟩)
  generalize_proofs at *; exact ⟨m, hm.left, by
    funext ⟨t, x⟩; simp [gridTranslate] at *; (
    -- By definition of gridTranslate, we have that applying it m times is equivalent to adding m times the translation vector.
    have h_iter : ∀ m : ℕ, ∀ (pt : SpacetimeGrid n D T), (gridTranslate n D T c₁)^[m] pt = (pt.1 + m * (c₁.p : ZMod T), fun i => pt.2 i + m * (c₁.s i : ZMod (D i))) := by
      exact gridTranslate_iterate n D T c₁
    generalize_proofs at *; (
    simp_all +decide [ funext_iff ]));⟩;

/-
Prove that condition (iii) implies condition (ii) to complete the equivalence.
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- Theorem 2: Exact Characterization of Universal Refinement and Monotonicity (Six-Way Equivalence). -/
theorem Theorem2 (c₁ c₂ : Candidate n) :
    (cond1_mod n D T c₁ c₂ ↔ cond2 n D T c₁ c₂) ∧
    (cond2 n D T c₁ c₂ ↔ cond3 n D T c₁ c₂) ∧
    (cond3 n D T c₁ c₂ ↔ cond4 n D T c₁ c₂) ∧
    (cond4 n D T c₁ c₂ ↔ cond5 n D T c₁ c₂) ∧
    (cond5 n D T c₁ c₂ ↔ cond6 n D T c₁ c₂) := by
  have h12 : cond1_mod n D T c₁ c₂ ↔ cond2 n D T c₁ c₂ := cond1_mod_iff_cond2 n D T c₁ c₂
  have h23 : cond2 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond2_imp_cond3 n D T c₁ c₂
  have h34 : cond3 n D T c₁ c₂ → cond4 n D T c₁ c₂ := cond3_imp_cond4 n D T c₁ c₂
  have h45 : cond4 n D T c₁ c₂ → cond5 n D T c₁ c₂ := cond4_imp_cond5 n D T c₁ c₂
  have h53 : cond5 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond5_imp_cond3 n D T c₁ c₂
  have h36 : cond3 n D T c₁ c₂ → cond6 n D T c₁ c₂ := cond3_imp_cond6_success n D T c₁ c₂
  have h63 : cond6 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond6_imp_cond3 n D T c₁ c₂

  have h35 : cond3 n D T c₁ c₂ ↔ cond5 n D T c₁ c₂ := ⟨fun h => h45 (h34 h), h53⟩
  have h36_iff : cond3 n D T c₁ c₂ ↔ cond6 n D T c₁ c₂ := ⟨h36, h63⟩

  have h32 : cond3 n D T c₁ c₂ → cond2 n D T c₁ c₂ := cond3_imp_cond2 n D T c₁ c₂
  refine ⟨h12, ⟨h23, h32⟩, ⟨h34, fun h => h53 (h45 h)⟩, ⟨h45, fun h => h34 (h53 h)⟩, ⟨?_, ?_⟩⟩
  · exact fun h => h36_iff.mp (h35.mpr h)
  · exact fun h => h35.mp (h36_iff.mpr h)

/-
Prove Theorem 2 (Final) by combining all the proved implications.
-/
open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- Theorem 2: Exact Characterization of Universal Refinement and Monotonicity (Six-Way Equivalence).
    This is the final version combining all proved lemmas. -/
theorem Theorem2_Final (c₁ c₂ : Candidate n) :
    (cond1_mod n D T c₁ c₂ ↔ cond2 n D T c₁ c₂) ∧
    (cond2 n D T c₁ c₂ ↔ cond3 n D T c₁ c₂) ∧
    (cond3 n D T c₁ c₂ ↔ cond4 n D T c₁ c₂) ∧
    (cond4 n D T c₁ c₂ ↔ cond5 n D T c₁ c₂) ∧
    (cond5 n D T c₁ c₂ ↔ cond6 n D T c₁ c₂) := by
  have h12 : cond1_mod n D T c₁ c₂ ↔ cond2 n D T c₁ c₂ := cond1_mod_iff_cond2 n D T c₁ c₂
  have h23 : cond2 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond2_imp_cond3 n D T c₁ c₂
  have h32 : cond3 n D T c₁ c₂ → cond2 n D T c₁ c₂ := cond3_imp_cond2 n D T c₁ c₂
  have h34 : cond3 n D T c₁ c₂ → cond4 n D T c₁ c₂ := cond3_imp_cond4 n D T c₁ c₂
  have h45 : cond4 n D T c₁ c₂ → cond5 n D T c₁ c₂ := cond4_imp_cond5 n D T c₁ c₂
  have h53 : cond5 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond5_imp_cond3 n D T c₁ c₂
  have h36 : cond3 n D T c₁ c₂ → cond6 n D T c₁ c₂ := cond3_imp_cond6_success n D T c₁ c₂
  have h63 : cond6 n D T c₁ c₂ → cond3 n D T c₁ c₂ := cond6_imp_cond3 n D T c₁ c₂
  
  have h23_iff : cond2 n D T c₁ c₂ ↔ cond3 n D T c₁ c₂ := ⟨h23, h32⟩
  have h34_iff : cond3 n D T c₁ c₂ ↔ cond4 n D T c₁ c₂ := ⟨h34, fun h => h53 (h45 h)⟩
  have h45_iff : cond4 n D T c₁ c₂ ↔ cond5 n D T c₁ c₂ := ⟨h45, fun h => h34 (h53 h)⟩
  have h56_iff : cond5 n D T c₁ c₂ ↔ cond6 n D T c₁ c₂ := ⟨fun h => h36 (h53 h), fun h => h45 (h34 (h63 h))⟩
  
  exact ⟨h12, h23_iff, h34_iff, h45_iff, h56_iff⟩

