open BigOperators Classical

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

lemma orbitPartition_isPartition (c : Candidate n) :
  Setoid.IsPartition (orbitPartition n D T c) := by
  -- The orbit partition is an equivalence relation, so it is a partition.
  have h_partition : ∀ x y : SpacetimeGrid n D T, (y ∈ gridOrbit n D T c x) ↔ (x ∈ gridOrbit n D T c y) := by
    intro x y; constructor <;> intro h <;> obtain ⟨ k, rfl ⟩ := h;
    · -- Since the grid is finite, the sequence of translations must eventually repeat. Therefore, there exists some $m$ such that applying the translation $m$ times brings $x$ back to itself.
      obtain ⟨m, hm⟩ : ∃ m : ℕ, m > 0 ∧ (gridTranslate n D T c)^[m] x = x := by
        have h_finite : Set.Finite (Set.range (fun k : ℕ => (gridTranslate n D T c)^[k] x)) := by
          exact Set.toFinite _;
        -- Since the range is finite, there must exist distinct natural numbers $i$ and $j$ such that $(gridTranslate n D T c)^[i] x = (gridTranslate n D T c)^[j] x$.
        obtain ⟨i, j, hij, h_eq⟩ : ∃ i j : ℕ, i < j ∧ (gridTranslate n D T c)^[i] x = (gridTranslate n D T c)^[j] x := by
          contrapose! h_finite;
          exact Set.infinite_range_of_injective fun i j hij => le_antisymm ( le_of_not_gt fun hi => h_finite _ _ hi hij.symm ) ( le_of_not_gt fun hj => h_finite _ _ hj hij );
        refine' ⟨ j - i, tsub_pos_of_lt hij, _ ⟩;
        rw [ ← Nat.add_sub_of_le hij.le, Function.iterate_add_apply ] at h_eq;
        exact Function.Injective.iterate ( show Function.Injective ( gridTranslate n D T c ) from by
                                            intro x y hxy; simp_all +decide [ Function.Injective, gridTranslate ] ;
                                            exact Prod.ext hxy.1 ( funext fun i => by simpa using congr_fun hxy.2 i ) ) i h_eq.symm;
      use m * (k + 1) - k;
      rw [ ← Function.iterate_add_apply, Nat.sub_add_cancel ( by nlinarith ) ];
      rw [ Function.iterate_mul, Function.iterate_fixed hm.2 ];
    · -- Since the grid is finite, the translation map τ is a permutation, so applying it multiple times will eventually return to the original point. Therefore, there exists some m such that τ^m(y) = y.
      have h_perm : ∃ m : ℕ, m > 0 ∧ (gridTranslate n D T c)^[m] y = y := by
        -- Since the grid is finite, the translation map τ is a permutation, so applying it multiple times will eventually return to the original point. Therefore, there exists some m such that τ^m(y) = y. Use this fact.
        have h_perm : Function.Bijective (gridTranslate n D T c) := by
          have h_perm : Function.Injective (gridTranslate n D T c) := by
            intro x y hxy; simp_all +decide [ Function.Injective, gridTranslate ] ;
            exact Prod.ext hxy.1 ( funext fun i => by simpa using congr_fun hxy.2 i );
          exact ⟨ h_perm, Finite.injective_iff_surjective.mp h_perm ⟩;
        have h_perm : ∃ m : ℕ, m > 0 ∧ (gridTranslate n D T c)^[m] = id := by
          refine ⟨orderOf (Equiv.ofBijective (gridTranslate n D T c) h_perm), orderOf_pos _, ?_⟩
          show (⇑(Equiv.ofBijective (gridTranslate n D T c) h_perm))^[orderOf
            (Equiv.ofBijective (gridTranslate n D T c) h_perm)] = id
          rw [← Equiv.Perm.coe_pow, pow_orderOf_eq_one, Equiv.Perm.coe_one]
        exact ⟨ h_perm.choose, h_perm.choose_spec.1, congr_fun h_perm.choose_spec.2 y ⟩;
      obtain ⟨ m, hm₁, hm₂ ⟩ := h_perm; use m * ( k + 1 ) - k; simp_all +decide [ ← Function.iterate_add_apply, Nat.sub_add_cancel ( show k ≤ m * ( k + 1 ) from by nlinarith ) ] ;
      rw [ Function.iterate_mul, Function.iterate_fixed hm₂ ];
