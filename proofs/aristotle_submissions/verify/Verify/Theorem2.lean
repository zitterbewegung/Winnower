open BigOperators

section Definitions

variable (n : ℕ) (D : Fin n → ℕ) (T : ℕ)
variable [NeZero T] [∀ i, NeZero (D i)]

/-- The spacetime grid on a torus. -/
abbrev SpacetimeGrid := ZMod T × ((i : Fin n) → ZMod (D i))

/-- A relative-periodic candidate c = (p, s). -/
structure Candidate where
  p : ℕ
  s : (i : Fin n) → ℤ

/-- The translation action induced by a candidate. -/
def gridTranslate (c : Candidate n) (pt : SpacetimeGrid n D T) : SpacetimeGrid n D T :=
  let (t, x) := pt
  (t + c.p, fun i => x i + c.s i)

/-- The orbit of a point under the translation action. -/
def gridOrbit (c : Candidate n) (pt : SpacetimeGrid n D T) : Set (SpacetimeGrid n D T) :=
  { pt' | ∃ k : ℕ, pt' = (gridTranslate n D T c)^[k] pt }

/-- The partition of the grid into orbits. -/
def orbitPartition (c : Candidate n) : Set (Set (SpacetimeGrid n D T)) :=
  { o | ∃ pt, o = gridOrbit n D T c pt }

/-- A binary field on the spacetime grid. -/
def BinaryField := SpacetimeGrid n D T → Bool

/-- The model class B(c) consists of all binary fields constant on orbit classes. -/
def ModelClass (c : Candidate n) : Set (BinaryField n D T) :=
  { U | ∀ o ∈ orbitPartition n D T c, ∀ x y, x ∈ o → y ∈ o → U x = U y }

end Definitions

/-
Define minHammingDist as the minimum Hamming distance from U to the model class.
