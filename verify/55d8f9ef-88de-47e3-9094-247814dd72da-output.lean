/-
A binary spacetime is a function from indices to Booleans.
-/
def Spacetime (ι : Type*) := ι → Bool

/-
The empirical probability of 1s in a subset of the spacetime.
-/
noncomputable def empiricalProb {ι : Type*} [Fintype ι] [DecidableEq ι] (U : Spacetime ι) (s : Finset ι) : ℝ :=
  (s.filter (fun i => U i)).card / s.card

/-
The NLL contribution of a single part of the partition.
-/
noncomputable def partNLL {ι : Type*} [Fintype ι] [DecidableEq ι] (U : Spacetime ι) (s : Finset ι) : ℝ :=
  s.card * Real.binEntropy (empiricalProb U s)

/-
The total NLL of a spacetime with respect to a partition.
-/
noncomputable def totalNLL {ι : Type*} [Fintype ι] [DecidableEq ι] (U : Spacetime ι) (P : Finpartition (Finset.univ : Finset ι)) : ℝ :=
  ∑ s ∈ P.parts, partNLL U s

/-
A spacetime is constant on a partition if it takes the same value for all elements in each part.
-/
def isConstantOn {ι : Type*} [Fintype ι] [DecidableEq ι] (U : Spacetime ι) (P : Finpartition (Finset.univ : Finset ι)) : Prop :=
  ∀ s ∈ P.parts, ∀ i j, i ∈ s → j ∈ s → U i = U j

